---
import Layout from '../layouts/Layout.astro';
import { supabase, optimizarImagen } from '../lib/supabase';
import MapaInteractivo from '../components/MapaInteractivo.astro';
import { ESTADOS, COORDENADAS_ESTADOS } from "../data/venezuela";
import { normalizarBusqueda } from '../utils/stringUtils';

let mensaje = '';
let mensajeTipo = ''; // 'success' o 'error'

// Procesar el formulario si es POST (Zero-JS)
if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const action = data.get('action')?.toString() || 'crear';

    if (action === 'resolver_suministro') {
      const id = data.get('id')?.toString();
      const token_edicion = data.get('token_edicion')?.toString();
      if (!id || !token_edicion) throw new Error('Datos inválidos');
      const { error } = await supabase.from('suministros_ayuda').update({ resuelto: true }).eq('id', id).eq('token_edicion', token_edicion);
      if (error) throw new Error('No se pudo resolver el anuncio.');
      mensaje = '¡Anuncio marcado como resuelto! Ya no aparecerá en la lista activa.';
      mensajeTipo = 'success';
    } else {
      // Extrayendo y limpiando datos
      const tipo_anuncio = data.get('tipo_anuncio')?.toString() || 'NECESITO';
      const categoria = data.get('categoria')?.toString() || 'OTROS';
      const titulo_item = data.get('titulo_item')?.toString().trim() || '';
      const descripcion = data.get('descripcion')?.toString().trim() || '';
      const cantidad_existencias = parseInt(data.get('cantidad_existencias')?.toString() || '1', 10);
      const unidad_medida = data.get('unidad_medida')?.toString() || 'unidades';
      const estado = data.get('estado')?.toString().trim() || '';
      const ciudad_municipio = data.get('ciudad_municipio')?.toString().trim() || '';
      const direccion_referencia = data.get('direccion_referencia')?.toString().trim() || '';
      const contacto = data.get('contacto')?.toString().trim() || '';
      
      const latStr = data.get('latitud')?.toString();
      let latitud = latStr ? parseFloat(latStr) : null;
      const lonStr = data.get('longitud')?.toString();
      let longitud = lonStr ? parseFloat(lonStr) : null;
      const imagen_url = data.get('imagen_url')?.toString().trim() || null;

      if (!titulo_item || !estado || !ciudad_municipio || !contacto) {
        throw new Error("Faltan campos obligatorios");
      }

      // GEOCODIFICACIÓN SERVER-SIDE
      if ((!latitud || !longitud || isNaN(latitud)) && direccion_referencia && ciudad_municipio && estado) {
        try {
          const queryGeocode = `${direccion_referencia}, ${ciudad_municipio}, ${estado}, Venezuela`;
          const res = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(queryGeocode)}&limit=1`, {
            headers: { 'User-Agent': 'RedSolidaridadVenezuela/1.0' }
          });
          const geoData = await res.json();
          if (geoData && geoData.length > 0) {
            latitud = parseFloat(geoData[0].lat);
            longitud = parseFloat(geoData[0].lon);
          } else {
            const resFallback = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(ciudad_municipio + ', ' + estado + ', Venezuela')}&limit=1`, {
              headers: { 'User-Agent': 'RedSolidaridadVenezuela/1.0' }
            });
            const geoFallback = await resFallback.json();
            if (geoFallback && geoFallback.length > 0) {
              latitud = parseFloat(geoFallback[0].lat);
              longitud = parseFloat(geoFallback[0].lon);
            }
          }
        } catch (e) {
          console.error("Error en geocodificación server-side:", e);
        }
      }

      if (isNaN(cantidad_existencias) || cantidad_existencias < 1) {
        throw new Error("La cantidad de existencias debe ser al menos 1");
      }

      const token_edicion = crypto.randomUUID();

      // Insertar en Supabase
      const { error } = await supabase.from('suministros_ayuda').insert([
        { 
          tipo_anuncio,
          categoria,
          titulo_item,
          descripcion,
          cantidad_existencias,
          unidad_medida,
          estado,
          ciudad_municipio,
          direccion_referencia,
          contacto,
          resuelto: false,
          latitud: latitud,
          longitud: longitud,
          imagen_url,
          token_edicion
        }
      ]);

      if (error) {
        console.error(error);
        throw new Error("Error al guardar en la base de datos.");
      }
      
      mensaje = 'Anuncio guardado con éxito. Desde este dispositivo podrás marcarlo como resuelto cuando ya no esté disponible.';
      mensajeTipo = 'success';
      // @ts-ignore
      Astro.locals._nuevoToken = token_edicion;
    }
  } catch (error: any) {
    mensaje = error.message || 'Hubo un error al procesar el suministro.';
    mensajeTipo = 'error';
  }
}

// Búsqueda simple (si hay query string)
const url = new URL(Astro.request.url);
const buscar = url.searchParams.get('q') || '';
const ubicacion = url.searchParams.get('ubicacion') || '';
const filtroTipo = url.searchParams.get('tipo') || ''; // 'TENGO' o 'NECESITO'
// @ts-ignore
const nuevoToken = Astro.locals._nuevoToken || '';

// Consultar los reportes activos
let query = supabase
  .from('suministros_ayuda')
  .select('*')
  .eq('resuelto', false)
  .order('creado_el', { ascending: false });

if (buscar) {
  const bNorm = normalizarBusqueda(buscar);
  query = query.or(`busqueda_general.ilike.%${bNorm}%`);
}

if (ubicacion) {
  const uNorm = normalizarBusqueda(ubicacion);
  query = query.or(`busqueda_ubicacion.ilike.%${uNorm}%`);
}

if (filtroTipo) {
  query = query.eq('tipo_anuncio', filtroTipo);
}

const { data: suministros, error: fetchError } = await query;

const nombresCategorias: Record<string, string> = {
  ALIMENTOS: 'Comida y Alimentos',
  MEDICINAS: 'Medicinas y Primeros Auxilios',
  AGUA: 'Agua Potable y Limpia',
  HIGIENE: 'Aseo e Higiene Personal',
  TRANSPORTE: 'Vehículos y Traslados',
  SALUD: 'Médico, Psicológico y Veterinario',
  VOLUNTARIADO: 'Voluntariado y Apoyo a Centros',
  OTROS: 'Otros Apoyos y Servicios'
};

// Preparar los marcadores para el mapa
const markerItems = (suministros || []).map(item => ({
  id: item.id,
  latitud: item.latitud ? parseFloat(item.latitud.toString()) : (COORDENADAS_ESTADOS[item.estado] ? COORDENADAS_ESTADOS[item.estado][0] + (Math.random() - 0.5) * 0.05 : null),
  longitud: item.longitud ? parseFloat(item.longitud.toString()) : (COORDENADAS_ESTADOS[item.estado] ? COORDENADAS_ESTADOS[item.estado][1] + (Math.random() - 0.5) * 0.05 : null),
  titulo: item.titulo_item,
  subtitulo: `${item.ciudad_municipio}, ${item.estado}`,
  descripcion: `[${nombresCategorias[item.categoria] || item.categoria}] ${item.descripcion || ''} - Cantidad: ${item.cantidad_existencias} ${item.unidad_medida}`,
  badge: item.tipo_anuncio === 'TENGO' ? 'TENGO' : 'NECESITO',
  badgeType: item.tipo_anuncio === 'TENGO' ? 'success' as const : 'danger' as const,
  contacto: item.contacto,
  imagen_url: item.imagen_url
}));
---

<Layout title="Ayuda y Comida">
	<div style="margin-bottom: 20px;">
		<a href="/" style="text-decoration: none; color: var(--accent);">← Volver al Inicio</a>
	</div>

	<h1 style="margin-bottom: 10px;">Ayuda y Comida</h1>
	<p style="margin-bottom: 20px; color: #555;">La solidaridad nos mantiene a flote. ¿Tienes agua o comida extra? ¿Puedes ofrecer transporte, asistencia médica o prestar un generador eléctrico? Ofrece tu ayuda, tu tiempo y recursos valen oro. Todos los campos con * son obligatorios.</p>

	<div class="card" style="background-color: var(--bg-gray); border: none; border-left: 5px solid var(--primary-blue); margin-bottom: 25px; border-radius: 4px;">
		<h3 style="margin-top: 0; margin-bottom: 10px; font-size: 1.15rem; color: var(--primary-blue);">💡 Ideas inspiradoras para ofrecer ayuda (¡Todo cuenta!)</h3>
		<ul style="padding-left: 20px; font-size: 0.95rem; line-height: 1.5; color: #444;">
			<li style="margin-bottom: 8px;"><strong>⚡ Energía y Conectividad:</strong> <em>"Generador para cargar el teléfono por horas"</em> o préstamo de baterías cargadas para que los vecinos no queden incomunicados.</li>
			<li style="margin-bottom: 8px;"><strong>🚗 Transporte y Logística:</strong> <em>"Tengo una camioneta y puedo ayudar a trasladar personas o suministros"</em>, o mover ramas/árboles de la vía.</li>
			<li style="margin-bottom: 8px;"><strong>🩺 Médicos, Enfermeros y Psicólogos:</strong> <em>"Apoyo psicológico telefónico"</em>, atención primaria de primeros auxilios, curas o consultas básicas de salud.</li>
			<li style="margin-bottom: 8px;"><strong>🐾 Veterinarios y Mascotas:</strong> Ofrecer atención a mascotas heridas o compartir comida para perros/gatos.</li>
			<li style="margin-bottom: 8px;"><strong>🤝 Voluntariado y Apoyo a Centros:</strong> <em>"Ayuda para clasificar donaciones en el centro parroquial"</em> o apoyo de voluntarios en albergues habilitados.</li>
			<li style="margin-bottom: 8px;"><strong>🌾 Alimentos y Agua:</strong> Compartir una comida caliente, agua potable limpia o botellas de agua.</li>
		</ul>
	</div>

	{mensaje && (
		<div class="card" style={`background-color: ${mensajeTipo === 'success' ? '#c8e6c9' : '#ffcdd2'}; border-color: ${mensajeTipo === 'success' ? '#81c784' : '#e57373'};`}>
			<strong>{mensajeTipo === 'success' ? 'Éxito:' : 'Error:'}</strong> {mensaje}
		</div>
	)}

	<details style="margin-bottom: 30px; border: 2px solid var(--primary-blue); background-color: #f0f7ff; padding: 24px; border-radius: 8px; box-shadow: 0 4px 12px rgba(0, 91, 181, 0.08);">
		<summary class="btn" style="display: flex; justify-content: center; align-items: center; gap: 10px; margin: 0 auto; max-width: 550px; font-size: 1.2rem; cursor: pointer; border: none; outline: none; box-shadow: 0 4px 10px rgba(0, 91, 181, 0.25);">
			🤝 Ofrecer Ayuda / Pedir Comida y Apoyo
		</summary>
		
		<div style="margin-top: 24px; background: #ffffff; padding: 20px; border-radius: 6px; border: 1px solid var(--border-color);">
			<form method="POST">
				<div class="form-group">
					<label>¿Qué deseas hacer? *</label>
					<select name="tipo_anuncio" required>
						<option value="NECESITO">Necesitamos este recurso con urgencia</option>
						<option value="TENGO">Tengo este recurso para donar/compartir</option>
					</select>
				</div>

				<div class="form-group">
					<label>Categoría *</label>
					<select name="categoria" required>
						<option value="ALIMENTOS">Comida y Alimentos Compartidos</option>
						<option value="MEDICINAS">Medicinas y Primeros Auxilios</option>
						<option value="AGUA">Agua Potable y Limpia</option>
						<option value="HIGIENE">Aseo e Higiene Personal</option>
						<option value="TRANSPORTE">Vehículos y Traslados</option>
						<option value="SALUD">Apoyo Médico, Psicológico y Veterinario</option>
						<option value="VOLUNTARIADO">Manos para Ayudar (Voluntarios y Centros de Donación)</option>
						<option value="OTROS">Otros Apoyos y Servicios</option>
					</select>
				</div>

				<div class="form-group">
					<label>Título del Recurso o Servicio *</label>
					<input type="text" name="titulo_item" placeholder="Ej: Generador para cargar el teléfono por horas, Harina de maíz, Camioneta para traslados" required />
				</div>

				<div style="display: flex; gap: 10px; flex-wrap: wrap;">
					<div class="form-group" style="flex: 2; min-width: 150px;">
						<label>Cantidad Disponible/Requerida *</label>
						<input type="number" name="cantidad_existencias" value="1" min="1" step="1" style="width: 100%; padding: 10px; border: 1px solid var(--border-color); border-radius: 4px; font-size: 1rem;" required />
					</div>
					<div class="form-group" style="flex: 1; min-width: 120px;">
						<label>Unidad *</label>
						<select name="unidad_medida" required>
							<option value="unidades">Unidades / Piezas</option>
							<option value="kilos">Kilogramos (kg)</option>
							<option value="litros">Litros (L)</option>
							<option value="paquetes">Paquetes / Bultos</option>
						</select>
					</div>
				</div>

				<div class="form-group">
					<label>Descripción detallada</label>
					<textarea name="descripcion" placeholder="Ej: Ofrezco encender la planta eléctrica de 6:00 PM a 9:00 PM en el porche para que carguen sus baterías. Traer su propio cargador."></textarea>
				</div>

				<div style="display: flex; gap: 10px; flex-wrap: wrap;">
					<div class="form-group" style="flex: 1; min-width: 150px;">
						<label>Estado *</label>
						<select name="estado" class="estado-select" required>
							<option value="">Selecciona un estado</option>
							{ESTADOS.map((e) => <option value={e}>{e}</option>)}
						</select>
					</div>
					<div class="form-group" style="flex: 1; min-width: 150px;">
						<label>Ciudad / Municipio *</label>
						<select name="ciudad_municipio" class="ciudad-select" required>
							<option value="">Primero selecciona un estado</option>
						</select>
					</div>
				</div>

				<div class="form-group">
					<label>Dirección exacta o Referencia de ubicación *</label>
					<input type="text" name="direccion_referencia" placeholder="Ej: Av. Francisco de Miranda, Edif. Roxana, PB" required />
				</div>

				<div class="form-group">
					<label>Información de Contacto *</label>
					<input type="text" name="contacto" placeholder="Ej: Teléfono, Telegram @usuario, Instagram @usuario" required />
					<small style="color: #666;">Indica la mejor forma para que se comuniquen contigo directamente.</small>
				</div>

				<div style="display: flex; gap: 10px; flex-wrap: wrap; align-items: flex-end;" class="form-group">
					<div style="flex: 1; min-width: 200px;">
						<label>Coordenadas GPS (Recomendado para el Mapa interactivo)</label>
						<div style="display: flex; gap: 8px;">
							<input type="text" id="input-lat" name="latitud" placeholder="Latitud (Ej: 10.496)" readonly style="background: var(--bg-gray); cursor: not-allowed;" />
							<input type="text" id="input-lon" name="longitud" placeholder="Longitud (Ej: -66.879)" readonly style="background: var(--bg-gray); cursor: not-allowed;" />
						</div>
					</div>
					<button type="button" id="btn-gps" class="btn btn-secondary" style="height: 48px; padding: 0 15px; font-size: 0.9rem; white-space: nowrap;">
						📍 Capturar GPS
					</button>
				</div>
				<div style="font-size: 0.85rem; color: #444; margin-top: -10px; margin-bottom: 5px; line-height: 1.4;">
					<strong>🔒 Privacidad y utilidad:</strong> Tu navegador te pedirá permiso (es totalmente seguro). Tu ubicación ayuda a que los vecinos que estén cerca puedan encontrar esta información fácilmente en el mapa interactivo. ¡Por favor, apruébalo!
				</div>
				<div id="gps-status" style="font-size: 0.85rem; color: #555; margin-bottom: 15px;"></div>

				<div class="form-group">
					<label>Foto del Recurso/Lugar (Opcional - Se comprime automáticamente)</label>
					<input type="file" id="image-file" accept="image/*" style="border: 2px solid var(--border-color); padding: 8px; width: 100%; border-radius: 6px; font-size: 0.95rem;" />
					<input type="hidden" name="imagen_url" id="input-imagen-url" />
					<div id="upload-status" style="font-size: 0.85rem; color: #555; margin-top: 5px;"></div>
				</div>

				<button type="submit">Publicar Anuncio</button>
			</form>
		</div>
	</details>

	<hr style="border: 0; border-top: 1px solid var(--border-color); margin: 30px 0;" />

	<h2>Anuncios de Ayuda y Comida</h2>

	<!-- Filtros y Búsqueda -->
	<form method="GET" style="background: none; border: none; padding: 0; margin-top: 10px; margin-bottom: 20px; display: flex; flex-direction: column; gap: 10px;">
		<div style="display: flex; gap: 10px; flex-wrap: wrap;">
			<input type="text" name="q" placeholder="Buscar ayuda, comida o servicio..." value={buscar} style="flex: 2; min-width: 200px;" />
			<input type="text" name="ubicacion" placeholder="📍 Ciudad o Estado..." value={ubicacion} style="flex: 1; min-width: 150px;" />
			<button type="submit" style="width: auto;">Buscar</button>
		</div>
		<div style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap;">
			<span style="font-size: 0.9rem; font-weight: bold;">Filtrar por tipo:</span>
			<a href={`/suministros?q=${buscar}&ubicacion=${ubicacion}`} class={`btn btn-secondary`} style={`width: auto; padding: 4px 10px; font-size: 0.85rem; ${!filtroTipo ? 'background-color: var(--primary-blue); color: white;' : ''}`}>Todos</a>
			<a href={`/suministros?q=${buscar}&ubicacion=${ubicacion}&tipo=TENGO`} class={`btn btn-secondary`} style={`width: auto; padding: 4px 10px; font-size: 0.85rem; ${filtroTipo === 'TENGO' ? 'background-color: var(--primary-blue); color: white;' : ''}`}>Ofertas (Tengo)</a>
			<a href={`/suministros?q=${buscar}&ubicacion=${ubicacion}&tipo=NECESITO`} class={`btn btn-secondary`} style={`width: auto; padding: 4px 10px; font-size: 0.85rem; ${filtroTipo === 'NECESITO' ? 'background-color: var(--primary-blue); color: white;' : ''}`}>Necesidades (Necesito)</a>
		</div>
	</form>

	<div style="margin-bottom: 25px;">
		<MapaInteractivo items={markerItems} mapId="mapa-suministros" />
	</div>

	<div class="lista">
		{fetchError && <p>Error al cargar los datos: {fetchError.message}</p>}
		
		{(!suministros || suministros.length === 0) && !fetchError && (
			<p>No se encontraron anuncios de ayuda o comida activos.</p>
		)}

		{suministros && suministros.map((item) => (
			<div class="card" data-token={item.token_edicion || ''} data-id={item.id} style={`border-left: 5px solid ${item.tipo_anuncio === 'TENGO' ? '#2e7d32' : 'var(--primary-blue)'}`}>
				<div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px;">
					<h3 style="margin: 0; font-size: 1.2rem;">{item.titulo_item}</h3>
					<div style="display: flex; gap: 5px;">
						<span class="badge badge-neutral">{nombresCategorias[item.categoria] || item.categoria}</span>
						<span class={`badge ${item.tipo_anuncio === 'TENGO' ? 'badge-success' : 'badge-danger'}`}>
							{item.tipo_anuncio === 'TENGO' ? 'TENGO / OFREZCO' : 'NECESITO'}
						</span>
					</div>
				</div>

				{item.imagen_url && (
					<details style="margin-bottom: 12px; max-width: 100%; border: none; padding: 0; background: transparent;">
						<summary class="btn btn-secondary" style="padding: 6px 12px; font-size: 0.85rem; display: inline-block; margin-bottom: 8px;">📷 Ver Foto Adjunta</summary>
						<img src={optimizarImagen(item.imagen_url)} alt={`Foto de ${item.titulo_item}`} class="img-zoomable" style="max-width: 100%; max-height: 250px; border-radius: 6px; object-fit: cover; border: 2px solid var(--border-color); display: block;" />
					</details>
				)}

				<p style="margin-bottom: 5px; font-size: 0.95rem;">
					<strong>Existencias:</strong> {item.cantidad_existencias} {item.unidad_medida}
				</p>
				
				{item.descripcion && (
					<p style="margin-bottom: 8px; font-size: 0.95rem; color: #333; background: var(--gray-light); padding: 8px; border-radius: 4px;">
						{item.descripcion}
					</p>
				)}

				<p style="margin-bottom: 5px; font-size: 0.95rem;">
					<strong>📍 Ubicación:</strong> {item.ciudad_municipio}, {item.estado} ({item.direccion_referencia})
				</p>

				<div style="display: flex; gap: 10px; margin-top: 12px; font-size: 0.9rem; align-items: center;">
					<span style="background: #eee; padding: 3px 8px; border-radius: 4px;">
						Contacto: <strong>{item.contacto}</strong>
					</span>
				</div>

				<!-- Botón owner: se muestra via JS -->
				<form method="POST" class="owner-actions" style="display: none; margin-top: 15px; padding-top: 15px; border-top: 1px dashed var(--border-color);">
					<input type="hidden" name="action" value="resolver_suministro" />
					<input type="hidden" name="id" value={item.id} />
					<input type="hidden" name="token_edicion" value={item.token_edicion} />
					<button type="submit" style="width: 100%; padding: 10px; background: #b45309; color: white;">✅ {item.tipo_anuncio === 'TENGO' ? 'Ya no disponible / Entregado' : 'Ya lo conseguí'}</button>
				</form>

				<p style="margin-top: 10px; font-size: 0.8rem; color: #777;" data-created={item.creado_el}>
					Publicado el {new Date(item.creado_el).toLocaleDateString('es-VE', { hour: '2-digit', minute:'2-digit' })}
				</p>
			</div>
		))}
	</div>

	<!-- Credenciales de Supabase en un contenedor oculto para uso del script del cliente -->
	<div id="credentials-holder" data-url={import.meta.env.SUPABASE_URL} data-key={import.meta.env.SUPABASE_ANON_KEY} data-nuevo-token={nuevoToken} style="display: none;"></div>

	<script>
	  import { compressAndUploadImage } from '../lib/clientStorage';

	  const holder = document.getElementById('credentials-holder');
	  const supabaseUrl = holder?.getAttribute('data-url') || '';
	  const supabaseAnonKey = holder?.getAttribute('data-key') || '';

	  // Geolocalización
	  const btnGps = document.getElementById('btn-gps');
	  const gpsStatus = document.getElementById('gps-status');
	  const inputLat = document.getElementById('input-lat') as HTMLInputElement;
	  const inputLon = document.getElementById('input-lon') as HTMLInputElement;

	  if (btnGps && gpsStatus && inputLat && inputLon) {
	    btnGps.addEventListener('click', () => {
	      gpsStatus.innerText = '⏳ Obteniendo GPS...';
	      if (!navigator.geolocation) {
	        gpsStatus.innerText = '❌ La geolocalización no está soportada en este navegador';
	        return;
	      }
	      navigator.geolocation.getCurrentPosition(
	        (position) => {
	          const lat = position.coords.latitude;
	          const lon = position.coords.longitude;
	          inputLat.value = lat.toFixed(6);
	          inputLon.value = lon.toFixed(6);
	          gpsStatus.innerHTML = `✅ Ubicación detectada con éxito.`;
	          gpsStatus.style.color = '#166534';
	        },
	        (error) => {
	          gpsStatus.innerText = `❌ Error: ${error.message}. Por favor actívalo manualmente.`;
	          gpsStatus.style.color = '#b91c1c';
	        },
	        { enableHighAccuracy: true, timeout: 8000 }
	      );
	    });
	  }

	  // Compresión y carga de imágenes
	  const imageFile = document.getElementById('image-file') as HTMLInputElement;
	  const inputImagenUrl = document.getElementById('input-imagen-url') as HTMLInputElement;
	  const uploadStatus = document.getElementById('upload-status');
	  const submitBtn = document.querySelector('form button[type="submit"]') as HTMLButtonElement;

	  if (imageFile && inputImagenUrl && uploadStatus && submitBtn) {
	    imageFile.addEventListener('change', async () => {
	      const file = imageFile.files?.[0];
	      if (!file) return;

	      try {
	        uploadStatus.innerText = '⏳ Optimizando foto en tu dispositivo...';
	        uploadStatus.style.color = '#555';
	        submitBtn.disabled = true;
	        submitBtn.style.opacity = '0.5';

	        const publicUrl = await compressAndUploadImage(file, supabaseUrl, supabaseAnonKey);
	        
	        inputImagenUrl.value = publicUrl;
	        uploadStatus.innerText = '✅ Foto subida y optimizada (~100KB) con éxito.';
	        uploadStatus.style.color = '#166534';
	      } catch (err: any) {
	        console.error(err);
	        uploadStatus.innerText = `❌ Error al subir la imagen: ${err.message || 'Error desconocido'}`;
	        uploadStatus.style.color = '#b91c1c';
	        imageFile.value = '';
	      } finally {
	        submitBtn.disabled = false;
	        submitBtn.style.opacity = '1';
	      }
	    });
	  }
	</script>
	<script>
		import { MUNICIPIOS_POR_ESTADO } from "../data/venezuela";

		document.addEventListener("DOMContentLoaded", () => {
			const estadoSelects = document.querySelectorAll(".estado-select");
			estadoSelects.forEach((estadoSelect) => {
				estadoSelect.addEventListener("change", (e) => {
					const target = e.target as HTMLSelectElement;
					const form = target.closest("form");
					if (!form) return;
					
					const ciudadSelect = form.querySelector(".ciudad-select") as HTMLSelectElement;
					if (!ciudadSelect) return;

					const estado = target.value;
					const municipios = MUNICIPIOS_POR_ESTADO[estado as keyof typeof MUNICIPIOS_POR_ESTADO] || [];

					ciudadSelect.innerHTML = '<option value="">Selecciona una ciudad o municipio</option>';
					municipios.forEach((m) => {
						const option = document.createElement("option");
						option.value = m;
						option.textContent = m;
						ciudadSelect.appendChild(option);
					});
				});
			});

			// Autocompletar coordenadas aproximadas si el usuario no usa GPS
			const ciudadSelects = document.querySelectorAll(".ciudad-select");
			ciudadSelects.forEach((ciudadSelect) => {
				ciudadSelect.addEventListener("change", (e) => {
					const target = e.target as HTMLSelectElement;
					const form = target.closest("form");
					if (!form) return;
					
					const estadoSelect = form.querySelector(".estado-select") as HTMLSelectElement;
					const inputLat = form.querySelector("input[name='latitud']") as HTMLInputElement;
					const inputLon = form.querySelector("input[name='longitud']") as HTMLInputElement;
					
					if (estadoSelect && target.value && inputLat && inputLon && !inputLat.value) {
						// Llamar a geocoding simple
						fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(target.value + ", " + estadoSelect.value + ", Venezuela")}`)
							.then(res => res.json())
							.then(data => {
								if (data && data.length > 0 && !inputLat.value) {
									inputLat.value = data[0].lat;
									inputLon.value = data[0].lon;
								}
							}).catch(() => {});
					}
				});
			});
		});
	</script>

	<!-- localStorage: guardar token y detectar posts propios -->
	<script is:inline>
		document.addEventListener("DOMContentLoaded", function() {
			var holder = document.getElementById("credentials-holder");
			var nuevoToken = holder ? holder.getAttribute("data-nuevo-token") : "";

			if (nuevoToken) {
				try {
					var tokens = JSON.parse(localStorage.getItem("mis_reportes_suministros") || "[]");
					tokens.push(nuevoToken);
					localStorage.setItem("mis_reportes_suministros", JSON.stringify(tokens));
				} catch(e) {}
			}

			try {
				var misTokens = JSON.parse(localStorage.getItem("mis_reportes_suministros") || "[]");
				if (misTokens.length > 0) {
					var cards = document.querySelectorAll(".card[data-token]");
					cards.forEach(function(card) {
						var cardToken = card.getAttribute("data-token");
						if (cardToken && misTokens.indexOf(cardToken) !== -1) {
							var ownerForm = card.querySelector(".owner-actions");
							if (ownerForm) ownerForm.style.display = "block";
						}
					});
				}
			} catch(e) {}

			// Relative time + age warning
			var timeEls = document.querySelectorAll("[data-created]");
			var now = new Date();
			timeEls.forEach(function(el) {
				var created = new Date(el.getAttribute("data-created"));
				var diffMs = now - created;
				var diffHours = Math.floor(diffMs / 3600000);
				var diffDays = Math.floor(diffHours / 24);
				var relText = "";
				if (diffDays > 0) relText = "Hace " + diffDays + (diffDays === 1 ? " día" : " días");
				else if (diffHours > 0) relText = "Hace " + diffHours + (diffHours === 1 ? " hora" : " horas");
				else relText = "Hace menos de 1 hora";
				el.textContent = relText;
				if (diffDays >= 3) {
					el.textContent = "⚠️ " + relText + " — verificar disponibilidad";
					el.style.color = "#b45309";
					el.style.fontWeight = "600";
				}
			});
		});
	</script>
</Layout>
