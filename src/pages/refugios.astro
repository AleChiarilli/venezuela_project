---
import Layout from '../layouts/Layout.astro';
import { supabase, optimizarImagen } from '../lib/supabase';
import MapaInteractivo from '../components/MapaInteractivo.astro';
import { ESTADOS, COORDENADAS_ESTADOS } from "../data/venezuela";
import { normalizarBusqueda } from '../utils/stringUtils';

let mensaje = '';
let mensajeTipo = ''; // 'success' o 'error'

// Procesar el formulario si es POST (Zero-JS)
if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const action = data.get('action')?.toString() || 'crear';

    if (action === 'resolver_refugio') {
      const id = data.get('id')?.toString();
      const token_edicion = data.get('token_edicion')?.toString();
      if (!id || !token_edicion) throw new Error('Datos inválidos');
      const { data, error } = await supabase.from('refugios_temporales').update({ resuelto: true }).eq('id', id).eq('token_edicion', token_edicion).select('id');
      if (error) throw new Error('No se pudo resolver el refugio.');
      if (!data || data.length === 0) throw new Error('No autorizado o registro no encontrado. (Falta política UPDATE en Supabase).');
      mensaje = '¡Refugio marcado como lleno/resuelto!';
      mensajeTipo = 'success';
    } else if (action === 'actualizar_capacidad') {
      const id = data.get('id')?.toString();
      const token_edicion = data.get('token_edicion')?.toString();
      const nueva_capacidad = parseInt(data.get('nueva_capacidad')?.toString() || '0', 10);
      if (!id || !token_edicion || nueva_capacidad < 0) throw new Error('Datos inválidos');
      const { data, error } = await supabase.from('refugios_temporales').update({ capacidad_personas: nueva_capacidad }).eq('id', id).eq('token_edicion', token_edicion).select('id');
      if (error) throw new Error('No se pudo actualizar la capacidad.');
      if (!data || data.length === 0) throw new Error('No autorizado o registro no encontrado. (Falta política UPDATE en Supabase).');
      mensaje = `¡Capacidad actualizada a ${nueva_capacidad} persona(s)!`;
      mensajeTipo = 'success';
    } else {
      const tipo_anuncio_ui = data.get('tipo_anuncio_ui')?.toString() || 'BUSCO_TECHO';
      const capacidad_personas = parseInt(data.get('capacidad_personas')?.toString() || '1', 10);
      const descripcion = data.get('descripcion')?.toString().trim() || '';
      const estado = data.get('estado')?.toString().trim() || '';
      const ciudad_municipio = data.get('ciudad_municipio')?.toString().trim() || '';
      const direccion_referencia = data.get('direccion_referencia')?.toString().trim() || '';
      let contacto = data.get('contacto')?.toString().trim() || '';
      
      const latStr = data.get('latitud')?.toString();
      let latitud = latStr ? parseFloat(latStr) : null;
      const lonStr = data.get('longitud')?.toString();
      let longitud = lonStr ? parseFloat(lonStr) : null;
      const imagen_url = data.get('imagen_url')?.toString().trim() || null;

      let tipo_anuncio = tipo_anuncio_ui;
      let descripcion_final = descripcion;

      if (tipo_anuncio_ui === 'REPORTO_PUBLICO') {
        tipo_anuncio = 'OFREZCO_TECHO';
        descripcion_final = "[REFUGIO PÚBLICO] " + descripcion;
        if (!contacto) {
          contacto = "Lugar Público (Acudir directamente)";
        }
      }

      if (!descripcion_final || !estado || !ciudad_municipio || !contacto) {
        throw new Error("Faltan campos obligatorios");
      }

      if (isNaN(capacidad_personas) || capacidad_personas < 1) {
        throw new Error("La capacidad de personas debe ser al menos 1");
      }

      // GEOCODIFICACIÓN SERVER-SIDE
      if ((!latitud || !longitud || isNaN(latitud as any)) && direccion_referencia && ciudad_municipio && estado) {
        try {
          const queryGeocode = `${direccion_referencia}, ${ciudad_municipio}, ${estado}, Venezuela`;
          const res = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(queryGeocode)}&limit=1`, {
            headers: { 'User-Agent': 'RedSolidaridadVenezuela/1.0' }
          });
          const geoData = await res.json();
          if (geoData && geoData.length > 0) {
            latitud = parseFloat(geoData[0].lat);
            longitud = parseFloat(geoData[0].lon);
          } else {
            const resFallback = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(ciudad_municipio + ', ' + estado + ', Venezuela')}&limit=1`, {
              headers: { 'User-Agent': 'RedSolidaridadVenezuela/1.0' }
            });
            const geoFallback = await resFallback.json();
            if (geoFallback && geoFallback.length > 0) {
              latitud = parseFloat(geoFallback[0].lat);
              longitud = parseFloat(geoFallback[0].lon);
            }
          }
        } catch (e) {
          console.error("Error en geocodificación server-side:", e);
        }
      }

      const token_edicion = crypto.randomUUID();

      const { error } = await supabase.from('refugios_temporales').insert([
        { 
          tipo_anuncio,
          capacidad_personas,
          descripcion: descripcion_final,
          estado,
          ciudad_municipio,
          direccion_referencia,
          contacto,
          resuelto: false,
          latitud: latitud,
          longitud: longitud,
          imagen_url,
          token_edicion
        }
      ]);

      if (error) {
        console.error(error);
        throw new Error("Error al guardar en la base de datos.");
      }
      
      mensaje = 'Refugio guardado con éxito. Desde este dispositivo podrás actualizar la capacidad o marcarlo como lleno.';
      mensajeTipo = 'success';
      // @ts-ignore
      Astro.locals._nuevoToken = token_edicion;
    }
  } catch (error: any) {
    mensaje = error.message || 'Hubo un error al procesar el refugio.';
    mensajeTipo = 'error';
  }
}

// Búsqueda simple (si hay query string)
const url = new URL(Astro.request.url);
const buscar = url.searchParams.get('q') || '';
const ubicacion = url.searchParams.get('ubicacion') || '';
const filtroTipo = url.searchParams.get('tipo') || ''; // 'OFREZCO_TECHO' o 'BUSCO_TECHO'
// @ts-ignore
const nuevoToken = Astro.locals._nuevoToken || '';

// Consultar los reportes activos
let query = supabase
  .from('refugios_temporales')
  .select('*')
  .eq('resuelto', false)
  .order('creado_el', { ascending: false });

if (buscar) {
  const bNorm = normalizarBusqueda(buscar);
  query = query.or(`busqueda_general.ilike.%${bNorm}%`);
}

if (ubicacion) {
  const uNorm = normalizarBusqueda(ubicacion);
  query = query.or(`busqueda_ubicacion.ilike.%${uNorm}%`);
}

if (filtroTipo) {
  query = query.eq('tipo_anuncio', filtroTipo);
}

const { data: refugios, error: fetchError } = await query;

// Preparar los marcadores para el mapa
const markerItems = (refugios || []).map(item => ({
  id: item.id,
  latitud: item.latitud ? parseFloat(item.latitud.toString()) : (COORDENADAS_ESTADOS[item.estado] ? COORDENADAS_ESTADOS[item.estado][0] + (Math.random() - 0.5) * 0.05 : null),
  longitud: item.longitud ? parseFloat(item.longitud.toString()) : (COORDENADAS_ESTADOS[item.estado] ? COORDENADAS_ESTADOS[item.estado][1] + (Math.random() - 0.5) * 0.05 : null),
  titulo: item.tipo_anuncio === 'OFREZCO_TECHO' ? 'Ofrece Refugio/Techo' : 'Busca Refugio/Techo',
  subtitulo: `${item.ciudad_municipio}, ${item.estado}`,
  descripcion: `Capacidad: ${item.capacidad_personas} pers. - ${item.descripcion}`,
  badge: item.tipo_anuncio === 'OFREZCO_TECHO' ? 'OFRECE' : 'BUSCA',
  badgeType: item.tipo_anuncio === 'OFREZCO_TECHO' ? 'success' as const : 'danger' as const,
  contacto: item.contacto,
  imagen_url: item.imagen_url
}));
---

<Layout title="Albergues y Refugios">
	<div style="margin-bottom: 20px;">
		<a href="/" style="text-decoration: none; color: var(--accent);">← Volver al Inicio</a>
	</div>

	<h1 style="margin-bottom: 10px;">Refugios y Techo Seguro</h1>
	<p style="margin-bottom: 20px; color: #555;">Ningún venezolano debería pasar la noche a la intemperie. ¿Tienes una habitación desocupada o un techo seguro? Ayuda a alguien que no tenga dónde pasar la noche. Tu hospitalidad puede salvar vidas. Todos los campos con * son obligatorios.</p>

	{mensaje && (
		<div class="card" style={`background-color: ${mensajeTipo === 'success' ? '#c8e6c9' : '#ffcdd2'}; border-color: ${mensajeTipo === 'success' ? '#81c784' : '#e57373'};`}>
			<strong>{mensajeTipo === 'success' ? 'Éxito:' : 'Error:'}</strong> {mensaje}
		</div>
	)}

	<details style="margin-bottom: 30px; border: 2px solid var(--primary-blue); background-color: #f0f7ff; padding: 24px; border-radius: 8px; box-shadow: 0 4px 12px rgba(0, 91, 181, 0.08);">
		<summary class="btn" style="display: flex; justify-content: center; align-items: center; gap: 10px; margin: 0 auto; max-width: 550px; font-size: 1.2rem; cursor: pointer; border: none; outline: none; box-shadow: 0 4px 10px rgba(0, 91, 181, 0.25);">
			🏠 Ofrecer Refugio / Solicitar Techo Seguro
		</summary>
		
		<div style="margin-top: 24px; background: #ffffff; padding: 20px; border-radius: 6px; border: 1px solid var(--border-color);">
			<form method="POST">
				<div class="form-group">
					<label>¿Qué deseas registrar? *</label>
					<select name="tipo_anuncio_ui" id="tipo_anuncio_select" required>
						<option value="BUSCO_TECHO">Necesitamos un lugar seguro donde dormir</option>
						<option value="OFREZCO_TECHO">Tengo un espacio seguro para alojar a otros (Soy dueño/admin)</option>
						<option value="REPORTO_PUBLICO">Estoy reportando un refugio público activo (Iglesia, colegio, etc.)</option>
					</select>
				</div>

				<div class="form-group">
					<label id="capacidad-label">Capacidad (Nro. aproximado de Personas) *</label>
					<input type="number" name="capacidad_personas" value="1" min="1" step="1" style="width: 100%; padding: 10px; border: 1px solid var(--border-color); border-radius: 4px; font-size: 1rem;" required />
				</div>

				<div class="form-group">
					<label id="descripcion-label">Descripción de las condiciones o requerimientos *</label>
					<textarea name="descripcion" id="descripcion-input" placeholder="Ej: Ofrezco habitación con baño privado y luz de planta eléctrica 2h al día. / Somos una familia de 3 adultos y 1 bebé con 1 perro buscando refugio." required></textarea>
				</div>

				<div style="display: flex; gap: 10px; flex-wrap: wrap;">
					<div class="form-group" style="flex: 1; min-width: 150px;">
						<label>Estado *</label>
						<select name="estado" class="estado-select" required>
							<option value="">Selecciona un estado</option>
							{ESTADOS.map((e) => <option value={e}>{e}</option>)}
						</select>
					</div>
					<div class="form-group" style="flex: 1; min-width: 150px;">
						<label>Ciudad / Municipio *</label>
						<select name="ciudad_municipio" class="ciudad-select" required>
							<option value="">Primero selecciona un estado</option>
						</select>
					</div>
				</div>

				<div class="form-group">
					<label id="direccion-label">Dirección exacta o Referencia de ubicación *</label>
					<input type="text" name="direccion_referencia" id="direccion-input" placeholder="Ej: Av. Francisco de Miranda, Edif. Roxana, PB" required />
				</div>

				<div class="form-group">
					<label id="contacto-label">Información de Contacto *</label>
					<input type="text" name="contacto" id="contacto-input" placeholder="Ej: Teléfono, Telegram @usuario, Instagram @usuario" required />
					<small id="contacto-help" style="color: #666;">Indica la mejor forma para que se comuniquen contigo directamente.</small>
				</div>

				<div style="display: flex; gap: 10px; flex-wrap: wrap; align-items: flex-end;" class="form-group">
					<div style="flex: 1; min-width: 200px;">
						<label>Coordenadas GPS (Opcional - Recomendado para el Mapa)</label>
						<div style="display: flex; gap: 8px;">
							<input type="text" id="input-lat" name="latitud" placeholder="Latitud (Ej: 10.496)" style="flex: 1; min-width: 80px;" />
							<input type="text" id="input-lon" name="longitud" placeholder="Longitud (Ej: -66.879)" style="flex: 1; min-width: 80px;" />
						</div>
					</div>
					<button type="button" id="btn-gps" class="btn btn-secondary" style="height: 48px; padding: 0 15px; font-size: 0.9rem; white-space: nowrap;">
						📍 Capturar mi GPS actual
					</button>
				</div>
				<div style="font-size: 0.85rem; color: #444; margin-top: -10px; margin-bottom: 5px; line-height: 1.4;">
					<strong>📍 Importante:</strong> Puedes presionar el botón para usar tu ubicación, o si reportas un lugar lejano, búscalo en Google Maps y escribe o pega manualmente las coordenadas aquí.
				</div>
				<div id="gps-status" style="font-size: 0.85rem; color: #555; margin-bottom: 15px;"></div>

				<div class="form-group">
					<label>Foto del Lugar (Opcional - Se comprime automáticamente)</label>
					<input type="file" id="image-file" accept="image/*" style="border: 2px solid var(--border-color); padding: 8px; width: 100%; border-radius: 6px; font-size: 0.95rem;" />
					<input type="hidden" name="imagen_url" id="input-imagen-url" />
					<div id="upload-status" style="font-size: 0.85rem; color: #555; margin-top: 5px;"></div>
				</div>

				<button type="submit">Publicar Refugio</button>
			</form>
		</div>
	</details>

	<hr style="border: 0; border-top: 1px solid var(--border-color); margin: 30px 0;" />

	<h2>Listado de Refugios</h2>

	<!-- Filtros y Búsqueda -->
	<form method="GET" style="background: none; border: none; padding: 0; margin-top: 10px; margin-bottom: 20px; display: flex; flex-direction: column; gap: 10px;">
		<div style="display: flex; gap: 10px; flex-wrap: wrap;">
			<input type="text" name="q" placeholder="Buscar por descripción..." value={buscar} style="flex: 2; min-width: 150px;" />
			<input type="text" name="ubicacion" placeholder="📍 Ciudad o Estado..." value={ubicacion} style="flex: 1; min-width: 150px;" />
			<button type="submit" style="width: auto;">Buscar</button>
		</div>
		<div style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap;">
			<span style="font-size: 0.9rem; font-weight: bold;">Filtrar por tipo:</span>
			<a href={`/refugios?q=${buscar}&ubicacion=${ubicacion}`} class={`btn btn-secondary`} style={`width: auto; padding: 4px 10px; font-size: 0.85rem; ${!filtroTipo ? 'background-color: var(--primary-blue); color: white;' : ''}`}>Todos</a>
			<a href={`/refugios?q=${buscar}&ubicacion=${ubicacion}&tipo=OFREZCO_TECHO`} class={`btn btn-secondary`} style={`width: auto; padding: 4px 10px; font-size: 0.85rem; ${filtroTipo === 'OFREZCO_TECHO' ? 'background-color: var(--primary-blue); color: white;' : ''}`}>Ofertas (Ofrezco Techo)</a>
			<a href={`/refugios?q=${buscar}&ubicacion=${ubicacion}&tipo=BUSCO_TECHO`} class={`btn btn-secondary`} style={`width: auto; padding: 4px 10px; font-size: 0.85rem; ${filtroTipo === 'BUSCO_TECHO' ? 'background-color: var(--primary-blue); color: white;' : ''}`}>Necesidades (Busco Techo)</a>
		</div>
	</form>

	<div style="margin-bottom: 25px;">
		<MapaInteractivo items={markerItems} mapId="mapa-refugios" />
	</div>

	<div class="lista">
		{fetchError && <p>Error al cargar los datos: {fetchError.message}</p>}
		
		{(!refugios || refugios.length === 0) && !fetchError && (
			<p>No se encontraron registros de refugios activos.</p>
		)}

		{refugios && refugios.map((item) => (
			<div class="card" data-token={item.token_edicion || ''} data-id={item.id} style={`border-left: 5px solid ${item.tipo_anuncio === 'OFREZCO_TECHO' ? '#2e7d32' : 'var(--primary-blue)'}`}>
				<div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px;">
					<h3 style="margin: 0; font-size: 1.2rem;">
						{item.tipo_anuncio === 'OFREZCO_TECHO' ? '🏠 Ofrece Refugio/Techo' : '🏠 Busca Refugio/Techo'}
					</h3>
					<span class={`badge ${item.tipo_anuncio === 'OFREZCO_TECHO' ? 'badge-success' : 'badge-danger'}`}>
						Capacidad: {item.capacidad_personas} {item.capacidad_personas === 1 ? 'persona' : 'personas'}
					</span>
				</div>
				
				{item.imagen_url && (
					<details style="margin-bottom: 12px; max-width: 100%; border: none; padding: 0; background: transparent;">
						<summary class="btn btn-secondary" style="padding: 6px 12px; font-size: 0.85rem; display: inline-block; margin-bottom: 8px;">📷 Ver Foto Adjunta</summary>
						<img src={optimizarImagen(item.imagen_url)} alt={`Foto de refugio`} class="img-zoomable" style="max-width: 100%; max-height: 250px; border-radius: 6px; object-fit: cover; border: 2px solid var(--border-color); display: block;" />
					</details>
				)}

				<p style="margin-bottom: 8px; font-size: 0.95rem; color: #333; background: var(--gray-light); padding: 8px; border-radius: 4px; white-space: pre-wrap;">
					{item.descripcion}
				</p>

				<p style="margin-bottom: 5px; font-size: 0.95rem;">
					<strong>📍 Ubicación:</strong> {item.ciudad_municipio}, {item.estado} ({item.direccion_referencia})
				</p>

				<div style="display: flex; gap: 10px; margin-top: 12px; font-size: 0.9rem; align-items: center;">
					<span style="background: #eee; padding: 3px 8px; border-radius: 4px;">
						Contacto: <strong>{item.contacto}</strong>
					</span>
				</div>

				<!-- Botón owner: se muestra via JS -->
				<div class="owner-actions" style="display: none; margin-top: 15px; padding-top: 15px; border-top: 1px dashed var(--border-color);">
					<div style="display: flex; gap: 10px; flex-wrap: wrap;">
						<form method="POST" style="flex: 1;">
							<input type="hidden" name="action" value="resolver_refugio" />
							<input type="hidden" name="id" value={item.id} />
							<input type="hidden" name="token_edicion" value={item.token_edicion} />
							<button type="submit" style="width: 100%; padding: 8px; background: #b91c1c; color: white; font-size: 0.85rem;">🚫 Lleno / Ya no disponible</button>
						</form>
						<form method="POST" style="flex: 1; display: flex; gap: 5px; align-items: stretch;">
							<input type="hidden" name="action" value="actualizar_capacidad" />
							<input type="hidden" name="id" value={item.id} />
							<input type="hidden" name="token_edicion" value={item.token_edicion} />
							<input type="number" name="nueva_capacidad" value={item.capacidad_personas} min="0" style="width: 70px; padding: 4px 8px; font-size: 0.9rem; border: 2px solid var(--border-color); border-radius: 4px;" />
							<button type="submit" style="padding: 8px 12px; background: var(--primary-blue); color: white; font-size: 0.85rem;">🔄 Actualizar</button>
						</form>
					</div>
				</div>

				<p style="margin-top: 10px; font-size: 0.8rem; color: #777;">
					Publicado el {new Date(item.creado_el).toLocaleDateString('es-VE', { hour: '2-digit', minute:'2-digit' })}
				</p>
			</div>
		))}
	</div>

	<!-- Credenciales de Supabase en un contenedor oculto para uso del script del cliente -->
	<div id="credentials-holder" data-url={import.meta.env.SUPABASE_URL} data-key={import.meta.env.SUPABASE_ANON_KEY} data-nuevo-token={nuevoToken} style="display: none;"></div>

	<script>
	  import { compressAndUploadImage } from '../lib/clientStorage';

	  const holder = document.getElementById('credentials-holder');
	  const supabaseUrl = holder?.getAttribute('data-url') || '';
	  const supabaseAnonKey = holder?.getAttribute('data-key') || '';

	  // Geolocalización
	  const btnGps = document.getElementById('btn-gps');
	  const gpsStatus = document.getElementById('gps-status');
	  const inputLat = document.getElementById('input-lat') as HTMLInputElement;
	  const inputLon = document.getElementById('input-lon') as HTMLInputElement;

	  if (btnGps && gpsStatus && inputLat && inputLon) {
	    btnGps.addEventListener('click', () => {
	      gpsStatus.innerText = '⏳ Obteniendo GPS...';
	      if (!navigator.geolocation) {
	        gpsStatus.innerText = '❌ La geolocalización no está soportada en este navegador';
	        return;
	      }
	      navigator.geolocation.getCurrentPosition(
	        (position) => {
	          const lat = position.coords.latitude;
	          const lon = position.coords.longitude;
	          inputLat.value = lat.toFixed(6);
	          inputLon.value = lon.toFixed(6);
	          gpsStatus.innerHTML = `✅ Ubicación detectada con éxito.`;
	          gpsStatus.style.color = '#166534';
	        },
	        (error) => {
	          gpsStatus.innerText = `❌ Error: ${error.message}. Por favor actívalo manualmente.`;
	          gpsStatus.style.color = '#b91c1c';
	        },
	        { enableHighAccuracy: true, timeout: 8000 }
	      );
	    });
	  }

	  // Compresión y carga de imágenes
	  const imageFile = document.getElementById('image-file') as HTMLInputElement;
	  const inputImagenUrl = document.getElementById('input-imagen-url') as HTMLInputElement;
	  const uploadStatus = document.getElementById('upload-status');
	  const submitBtn = document.querySelector('form button[type="submit"]') as HTMLButtonElement;

	  if (imageFile && inputImagenUrl && uploadStatus && submitBtn) {
	    imageFile.addEventListener('change', async () => {
	      const file = imageFile.files?.[0];
	      if (!file) return;

	      try {
	        uploadStatus.innerText = '⏳ Optimizando foto en tu dispositivo...';
	        uploadStatus.style.color = '#555';
	        submitBtn.disabled = true;
	        submitBtn.style.opacity = '0.5';

	        const publicUrl = await compressAndUploadImage(file, supabaseUrl, supabaseAnonKey);
	        
	        inputImagenUrl.value = publicUrl;
	        uploadStatus.innerText = '✅ Foto subida y optimizada (~100KB) con éxito.';
	        uploadStatus.style.color = '#166534';
	      } catch (err: any) {
	        console.error(err);
	        uploadStatus.innerText = `❌ Error al subir la imagen: ${err.message || 'Error desconocido'}`;
	        uploadStatus.style.color = '#b91c1c';
	        imageFile.value = '';
	      } finally {
	        submitBtn.disabled = false;
	        submitBtn.style.opacity = '1';
	      }
	    });
	  }
	</script>
	<script>
		import { MUNICIPIOS_POR_ESTADO } from "../data/venezuela";

		document.addEventListener("DOMContentLoaded", () => {
			const estadoSelects = document.querySelectorAll(".estado-select");
			estadoSelects.forEach((estadoSelect) => {
				estadoSelect.addEventListener("change", (e) => {
					const target = e.target as HTMLSelectElement;
					const form = target.closest("form");
					if (!form) return;
					
					const ciudadSelect = form.querySelector(".ciudad-select") as HTMLSelectElement;
					if (!ciudadSelect) return;

					const estado = target.value;
					const municipios = MUNICIPIOS_POR_ESTADO[estado as keyof typeof MUNICIPIOS_POR_ESTADO] || [];

					ciudadSelect.innerHTML = '<option value="">Selecciona una ciudad o municipio</option>';
					municipios.forEach((m) => {
						const option = document.createElement("option");
						option.value = m;
						option.textContent = m;
						ciudadSelect.appendChild(option);
					});
				});
			});

			// Autocompletar coordenadas aproximadas si el usuario no usa GPS
			const ciudadSelects = document.querySelectorAll(".ciudad-select");
			ciudadSelects.forEach((ciudadSelect) => {
				ciudadSelect.addEventListener("change", (e) => {
					const target = e.target as HTMLSelectElement;
					const form = target.closest("form");
					if (!form) return;
					
					const estadoSelect = form.querySelector(".estado-select") as HTMLSelectElement;
					const inputLat = form.querySelector("input[name='latitud']") as HTMLInputElement;
					const inputLon = form.querySelector("input[name='longitud']") as HTMLInputElement;
					
					if (estadoSelect && target.value && inputLat && inputLon && !inputLat.value) {
						// Llamar a geocoding simple
						fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(target.value + ", " + estadoSelect.value + ", Venezuela")}`)
							.then(res => res.json())
							.then(data => {
								if (data && data.length > 0 && !inputLat.value) {
									inputLat.value = data[0].lat;
									inputLon.value = data[0].lon;
								}
							}).catch(() => {});
					}
				});
			});

			const tipoAnuncioSelect = document.getElementById("tipo_anuncio_select") as HTMLSelectElement;
			const contactoInput = document.getElementById("contacto-input") as HTMLInputElement;
			const contactoLabel = document.getElementById("contacto-label");
			const contactoHelp = document.getElementById("contacto-help");

			const capacidadLabel = document.getElementById("capacidad-label");
			const descripcionLabel = document.getElementById("descripcion-label");
			const descripcionInput = document.getElementById("descripcion-input") as HTMLTextAreaElement;
			const direccionLabel = document.getElementById("direccion-label");
			const direccionInput = document.getElementById("direccion-input") as HTMLInputElement;

			if (tipoAnuncioSelect && contactoInput) {
				const updateLabels = () => {
					const val = tipoAnuncioSelect.value;
					
					if (val === "BUSCO_TECHO") {
						if(capacidadLabel) capacidadLabel.innerText = "¿Cuántas personas son en tu grupo? *";
						if(descripcionLabel) descripcionLabel.innerText = "Describe tu situación y qué necesitas *";
						if(descripcionInput) descripcionInput.placeholder = "Ej: Somos una familia de 3 adultos y 1 bebé con 1 perro. Necesitamos un lugar seguro donde dormir 2 noches.";
						if(direccionLabel) direccionLabel.innerText = "Zona donde te encuentras o donde buscas refugio *";
						if(direccionInput) direccionInput.placeholder = "Ej: Estoy cerca del C.C. Sambil o Busco por Chacao";
					} else {
						if(capacidadLabel) capacidadLabel.innerText = "Capacidad (Nro. aproximado de Personas que puedes alojar) *";
						if(descripcionLabel) descripcionLabel.innerText = "Descripción de las condiciones o reglas del lugar *";
						if(descripcionInput) descripcionInput.placeholder = "Ej: Ofrezco habitación con baño privado y luz de planta eléctrica 2h al día. No se aceptan mascotas.";
						if(direccionLabel) direccionLabel.innerText = "Dirección exacta o Referencia de ubicación *";
						if(direccionInput) direccionInput.placeholder = "Ej: Av. Francisco de Miranda, Edif. Roxana, PB";
					}

					if (val === "REPORTO_PUBLICO") {
						contactoInput.required = false;
						contactoInput.placeholder = "Opcional (Ej: número de la iglesia o lugar)";
						if(contactoLabel) contactoLabel.innerText = "Información de Contacto del lugar (Opcional)";
						if(contactoHelp) contactoHelp.innerText = "Si tienes un número de teléfono a mano para aportar es súper valioso y útil, aunque no seas el dueño. Si no lo conoces, puedes dejarlo en blanco.";
					} else {
						contactoInput.required = true;
						contactoInput.placeholder = "Ej: Teléfono, Telegram @usuario, Instagram @usuario";
						if(contactoLabel) contactoLabel.innerText = "Información de Contacto *";
						if(contactoHelp) contactoHelp.innerText = "Indica la mejor forma para que se comuniquen contigo directamente.";
					}
				};

				tipoAnuncioSelect.addEventListener("change", updateLabels);
				updateLabels(); // Ejecutar una vez al cargar
			}
		});
	</script>

	<!-- localStorage: guardar token y detectar posts propios -->
	<script is:inline>
		document.addEventListener("DOMContentLoaded", function() {
			var holder = document.getElementById("credentials-holder");
			var nuevoToken = holder ? holder.getAttribute("data-nuevo-token") : "";

			if (nuevoToken) {
				try {
					var tokens = JSON.parse(localStorage.getItem("mis_reportes_refugios") || "[]");
					tokens.push(nuevoToken);
					localStorage.setItem("mis_reportes_refugios", JSON.stringify(tokens));
				} catch(e) {}
			}

			try {
				var misTokens = JSON.parse(localStorage.getItem("mis_reportes_refugios") || "[]");
				if (misTokens.length > 0) {
					var cards = document.querySelectorAll(".card[data-token]");
					cards.forEach(function(card) {
						var cardToken = card.getAttribute("data-token");
						if (cardToken && misTokens.indexOf(cardToken) !== -1) {
							var ownerActions = card.querySelector(".owner-actions");
							if (ownerActions) ownerActions.style.display = "block";
						}
					});
				}
			} catch(e) {}
		});
	</script>
</Layout>
