---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase';
import { ESTADOS, MUNICIPIOS_POR_ESTADO } from "../data/venezuela";
import { normalizarBusqueda } from '../utils/stringUtils';

let mensaje = '';
let mensajeTipo = ''; // 'success' o 'error'

// Procesar el formulario si es POST (Zero-JS)
if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const action = data.get('action')?.toString() || 'crear';

    if (action === 'desactivar_numero') {
      const id = data.get('id')?.toString();
      const token_edicion = data.get('token_edicion')?.toString();
      if (!id || !token_edicion) throw new Error('Datos inválidos');
      const { error } = await supabase.from('numeros_emergencia').update({ activo: false }).eq('id', id).eq('token_edicion', token_edicion);
      if (error) throw new Error('No se pudo desactivar el número.');
      mensaje = '¡Número marcado como inactivo!';
      mensajeTipo = 'success';
    } else {
      const numero = data.get('numero')?.toString().trim() || '';
      const descripcion = data.get('descripcion')?.toString().trim() || '';
      const estado = data.get('estado')?.toString().trim() || '';
      const ciudad_municipio = data.get('ciudad_municipio')?.toString().trim() || '';

      if (!numero || !descripcion || !estado || !ciudad_municipio) {
        throw new Error("Faltan campos obligatorios");
      }

      const token_edicion = crypto.randomUUID();

      const { error } = await supabase.from('numeros_emergencia').insert([
        { 
          numero,
          descripcion,
          estado,
          ciudad_municipio,
          token_edicion,
          activo: true
        }
      ]);

      if (error) {
        console.error(error);
        throw new Error("Error al guardar en la base de datos.");
      }
      
      mensaje = 'Número guardado con éxito. Gracias por aportar a la comunidad.';
      mensajeTipo = 'success';
      // @ts-ignore
      Astro.locals._nuevoToken = token_edicion;
    }
  } catch (error: any) {
    mensaje = error.message || 'Hubo un error al procesar el número.';
    mensajeTipo = 'error';
  }
}

// Búsqueda simple (si hay query string)
const url = new URL(Astro.request.url);
const buscar = url.searchParams.get('q') || '';
const ubicacion = url.searchParams.get('ubicacion') || '';
// @ts-ignore
const nuevoToken = Astro.locals._nuevoToken || '';

// Consultar los números activos
let query = supabase
  .from('numeros_emergencia')
  .select('*')
  .eq('activo', true)
  .order('creado_el', { ascending: false });

if (buscar) {
  const bNorm = normalizarBusqueda(buscar);
  query = query.or(`busqueda_general.ilike.%${bNorm}%`);
}

if (ubicacion) {
  const uNorm = normalizarBusqueda(ubicacion);
  query = query.or(`busqueda_ubicacion.ilike.%${uNorm}%`);
}

const { data: numeros, error: fetchError } = await query;
---

<Layout title="Números Locales de Emergencia">
	<div style="margin-bottom: 20px;">
		<a href="/" style="text-decoration: none; color: var(--accent);">← Volver al Inicio</a>
	</div>

	<h1 style="margin-bottom: 10px;">Directorio de Números Locales de Emergencia</h1>
	<p style="margin-bottom: 20px; color: #555;">Busca números de asistencia específicos de tu estado o municipio, o aporta nuevos contactos (Bomberos locales, Protección Civil, ambulancias) para ayudar a los demás.</p>

	{mensaje && (
		<div class="card" style={`background-color: ${mensajeTipo === 'success' ? '#c8e6c9' : '#ffcdd2'}; border-color: ${mensajeTipo === 'success' ? '#81c784' : '#e57373'};`}>
			<strong>{mensajeTipo === 'success' ? 'Éxito:' : 'Error:'}</strong> {mensaje}
		</div>
	)}

	<details style="margin-bottom: 30px; border: 2px solid #c53030; background-color: #fff5f5; padding: 24px; border-radius: 8px; box-shadow: 0 4px 12px rgba(197, 48, 48, 0.08);">
		<summary class="btn" style="display: flex; justify-content: center; align-items: center; gap: 10px; margin: 0 auto; max-width: 550px; font-size: 1.2rem; cursor: pointer; border: none; outline: none; background-color: #c53030; box-shadow: 0 4px 10px rgba(197, 48, 48, 0.25);">
			➕ Agregar un Nuevo Número Local
		</summary>
		
		<div style="margin-top: 24px; background: #ffffff; padding: 20px; border-radius: 6px; border: 1px solid var(--border-color);">
			<form method="POST">
				<div class="form-group">
					<label>Nombre de la Institución o Servicio *</label>
					<input type="text" name="descripcion" placeholder="Ej: Bomberos de Chacao, Protección Civil Miranda, Ambulancias Privadas..." required />
				</div>

                <div class="form-group">
					<label>Número de Teléfono *</label>
					<input type="tel" name="numero" placeholder="Ej: 0212-1234567 o 0414-0000000" required />
				</div>

				<div style="display: flex; gap: 10px; flex-wrap: wrap;">
					<div class="form-group" style="flex: 1; min-width: 150px;">
						<label>Estado *</label>
						<select name="estado" class="estado-select" required>
							<option value="">Selecciona un estado</option>
							{ESTADOS.map((e) => <option value={e}>{e}</option>)}
						</select>
					</div>
					<div class="form-group" style="flex: 1; min-width: 150px;">
						<label>Ciudad / Municipio *</label>
						<select name="ciudad_municipio" class="ciudad-select" required>
							<option value="">Primero selecciona un estado</option>
						</select>
					</div>
				</div>

				<button type="submit" style="background-color: #c53030;">Publicar Número</button>
			</form>
		</div>
	</details>

	<hr style="border: 0; border-top: 1px solid var(--border-color); margin: 30px 0;" />

	<h2>Directorio por Estado</h2>

	<!-- Filtros y Búsqueda -->
	<form method="GET" style="background: none; border: none; padding: 0; margin-top: 10px; margin-bottom: 20px; display: flex; flex-direction: column; gap: 10px;">
		<div style="display: flex; gap: 10px; flex-wrap: wrap;">
			<input type="text" name="q" placeholder="Buscar institución (Ej: Bomberos)..." value={buscar} style="flex: 2; min-width: 150px;" />
			<input type="text" name="ubicacion" placeholder="📍 Buscar Estado o Ciudad..." value={ubicacion} style="flex: 1; min-width: 150px;" />
			<button type="submit" style="width: auto; background-color: #c53030;">Buscar</button>
		</div>
	</form>

	<div class="lista" style="grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));">
		{fetchError && <p>Error al cargar los datos: {fetchError.message}</p>}
		
		{(!numeros || numeros.length === 0) && !fetchError && (
			<p>No se encontraron registros activos. ¡Sé el primero en registrar un número de tu municipio!</p>
		)}

		{numeros && numeros.map((item) => (
			<div class="card" data-token={item.token_edicion || ''} data-id={item.id} style={`border-left: 5px solid #c53030`}>
				<div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px;">
					<h3 style="margin: 0; font-size: 1.2rem; color: #1a202c;">
						{item.descripcion}
					</h3>
				</div>
                
                <a href={`tel:${item.numero.replace(/[^0-9+]/g, '')}`} style="display: block; font-size: 1.5rem; font-weight: bold; color: #c53030; text-decoration: none; margin-bottom: 12px;">
                    📞 {item.numero}
                </a>

				<p style="margin-bottom: 5px; font-size: 0.95rem;">
					<strong>📍 Ubicación:</strong> {item.ciudad_municipio}, {item.estado}
				</p>

				<!-- Botón owner: se muestra via JS -->
				<div class="owner-actions" style="display: none; margin-top: 15px; padding-top: 15px; border-top: 1px dashed var(--border-color);">
					<div style="display: flex; gap: 10px; flex-wrap: wrap;">
						<form method="POST" style="flex: 1;">
							<input type="hidden" name="action" value="desactivar_numero" />
							<input type="hidden" name="id" value={item.id} />
							<input type="hidden" name="token_edicion" value={item.token_edicion} />
							<button type="submit" style="width: 100%; padding: 8px; background: #b91c1c; color: white; font-size: 0.85rem;">🚫 Este número ya no funciona (Borrar)</button>
						</form>
					</div>
				</div>

				<p style="margin-top: 10px; font-size: 0.8rem; color: #777;">
					Agregado el {new Date(item.creado_el).toLocaleDateString('es-VE')}
				</p>
			</div>
		))}
	</div>

	<!-- Credenciales ocultas para uso del script del cliente -->
	<div id="credentials-holder" data-nuevo-token={nuevoToken} style="display: none;"></div>

    <script>
		import { MUNICIPIOS_POR_ESTADO } from "../data/venezuela";

		document.addEventListener("DOMContentLoaded", () => {
			const estadoSelects = document.querySelectorAll(".estado-select");
			estadoSelects.forEach((estadoSelect) => {
				estadoSelect.addEventListener("change", (e) => {
					const target = e.target as HTMLSelectElement;
					const form = target.closest("form");
					if (!form) return;
					
					const ciudadSelect = form.querySelector(".ciudad-select") as HTMLSelectElement;
					if (!ciudadSelect) return;

					const estado = target.value;
					const municipios = MUNICIPIOS_POR_ESTADO[estado as keyof typeof MUNICIPIOS_POR_ESTADO] || [];

					ciudadSelect.innerHTML = '<option value="">Selecciona una ciudad o municipio</option>';
					municipios.forEach((m) => {
						const option = document.createElement("option");
						option.value = m;
						option.textContent = m;
						ciudadSelect.appendChild(option);
					});
				});
			});
		});
	</script>

	<!-- localStorage: guardar token y detectar posts propios -->
	<script is:inline>
		document.addEventListener("DOMContentLoaded", function() {
			var holder = document.getElementById("credentials-holder");
			var nuevoToken = holder ? holder.getAttribute("data-nuevo-token") : "";

			if (nuevoToken) {
				try {
					var tokens = JSON.parse(localStorage.getItem("mis_reportes_numeros") || "[]");
					tokens.push(nuevoToken);
					localStorage.setItem("mis_reportes_numeros", JSON.stringify(tokens));
				} catch(e) {}
			}

			try {
				var misTokens = JSON.parse(localStorage.getItem("mis_reportes_numeros") || "[]");
				if (misTokens.length > 0) {
					var cards = document.querySelectorAll(".card[data-token]");
					cards.forEach(function(card) {
						var cardToken = card.getAttribute("data-token");
						if (cardToken && misTokens.indexOf(cardToken) !== -1) {
							var ownerActions = card.querySelector(".owner-actions");
							if (ownerActions) ownerActions.style.display = "block";
						}
					});
				}
			} catch(e) {}
		});
	</script>
</Layout>
