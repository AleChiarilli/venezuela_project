---
import Layout from "../layouts/Layout.astro";
import { supabase, optimizarImagen } from "../lib/supabase";
import MapaInteractivo from "../components/MapaInteractivo.astro";
import { ESTADOS, COORDENADAS_ESTADOS } from "../data/venezuela";
import { normalizarBusqueda } from '../utils/stringUtils';

let mensaje = "";
let mensajeTipo = ""; // 'success' o 'error'

// Procesar el formulario si es POST (Zero-JS)
if (Astro.request.method === "POST") {
	try {
		const data = await Astro.request.formData();
		const action = data.get("action")?.toString() || "crear";

		if (action === "marcar_localizado") {
			const id = data.get("id")?.toString();
			const token_edicion = data.get("token_edicion")?.toString();

			if (!id || !token_edicion) throw new Error("Datos inválidos para actualizar");

			const { data: updateData, error } = await supabase
				.from("personas_busquedas")
				.update({ estado_vital: "A SALVO", estatus_actual: "RESUELTO" })
				.eq("id", id)
				.eq("token_edicion", token_edicion)
				.select("id");
			
			if (error) throw new Error("No se pudo actualizar el estado en la base de datos.");
			if (!updateData || updateData.length === 0) throw new Error("No autorizado o registro no encontrado. (Es posible que falte la política UPDATE en Supabase).");
			
			mensaje = "¡Persona marcada como localizada! Gracias por avisar. Su ficha se moverá a la sección de localizados.";
			mensajeTipo = "success";
		} else {
			// Extrayendo y limpiando datos
			const tipo_reporte = data.get("tipo_reporte")?.toString() || "BUSCO";
			const nombre_completo = data.get("nombre_completo")?.toString().trim() || "";
			const estado = data.get("estado")?.toString().trim() || "";
			const ciudad_municipio = data.get("ciudad_municipio")?.toString().trim() || "";
			const direccion_referencia = data.get("direccion_referencia")?.toString().trim() || "";
			const vestimenta_rasgos = data.get("vestimenta_rasgos")?.toString().trim() || "";
			const contacto_reportante = data.get("contacto_reportante")?.toString().trim() || "";
			const estado_vital = data.get("estado_vital")?.toString() || "DESAPARECIDO";

			const latStr = data.get("latitud")?.toString();
			let latitud = latStr ? parseFloat(latStr) : null;
			const lonStr = data.get("longitud")?.toString();
			let longitud = lonStr ? parseFloat(lonStr) : null;
			const imagen_url = data.get("imagen_url")?.toString().trim() || null;

			if (!nombre_completo || !estado || !ciudad_municipio || !contacto_reportante) {
				throw new Error("Faltan campos obligatorios");
			}

			// GEOCODIFICACIÓN SERVER-SIDE
			if ((!latitud || !longitud || isNaN(latitud)) && direccion_referencia && ciudad_municipio && estado) {
				try {
					const queryGeocode = `${direccion_referencia}, ${ciudad_municipio}, ${estado}, Venezuela`;
					const res = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(queryGeocode)}&limit=1`, {
						headers: { 'User-Agent': 'RedSolidaridadVenezuela/1.0' }
					});
					const geoData = await res.json();
					if (geoData && geoData.length > 0) {
						latitud = parseFloat(geoData[0].lat);
						longitud = parseFloat(geoData[0].lon);
					} else {
						const resFallback = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(ciudad_municipio + ', ' + estado + ', Venezuela')}&limit=1`, {
							headers: { 'User-Agent': 'RedSolidaridadVenezuela/1.0' }
						});
						const geoFallback = await resFallback.json();
						if (geoFallback && geoFallback.length > 0) {
							latitud = parseFloat(geoFallback[0].lat);
							longitud = parseFloat(geoFallback[0].lon);
						}
					}
				} catch (e) {
					console.error("Error en geocodificación server-side:", e);
				}
			}

			// Generar token secreto de edición
			const token_edicion = crypto.randomUUID();

			// Insertar en Supabase
			const { error } = await supabase.from("personas_busquedas").insert([
				{
					tipo_reporte,
					nombre_completo,
					estado,
					ciudad_municipio,
					direccion_referencia,
					vestimenta_rasgos,
					contacto_reportante,
					estado_vital,
					estatus_actual: "ACTIVO",
					latitud: latitud,
					longitud: longitud,
					imagen_url,
					token_edicion
				},
			]);

			if (error) {
				console.error(error);
				throw new Error("Error al guardar en la base de datos.");
			}

			mensaje = `Reporte guardado con éxito. Tu reporte aparecerá en la lista. Desde este mismo dispositivo podrás marcarlo como localizado cuando lo encuentres.`;
			mensajeTipo = "success";
			// We pass the token via a special variable so the client script can store it
			// @ts-ignore
			Astro.locals._nuevoToken = token_edicion;
		}
	} catch (error: any) {
		mensaje = error.message || "Hubo un error al procesar el reporte.";
		mensajeTipo = "error";
	}
}

// Búsqueda simple (si hay query string)
const url = new URL(Astro.request.url);
const buscar = url.searchParams.get("q") || "";
const ubicacion = url.searchParams.get("ubicacion") || "";
const editToken = url.searchParams.get("edit") || "";
const filtroEstado = url.searchParams.get("estado_vital") || "";
// @ts-ignore
const nuevoToken = Astro.locals._nuevoToken || "";

// Consultar los reportes - incluir resueltos para mostrarlos al final
let query = supabase
	.from("personas_busquedas")
	.select("*")
	.order("created_at", { ascending: false });

if (filtroEstado === "DESAPARECIDO") {
	query = query.eq("estatus_actual", "ACTIVO").eq("estado_vital", "DESAPARECIDO");
} else if (filtroEstado === "A SALVO") {
	query = query.eq("estado_vital", "A SALVO");
} else {
	// Default: show active first, then resolved
	query = query.in("estatus_actual", ["ACTIVO", "RESUELTO"]);
}

if (buscar) {
	const bNorm = normalizarBusqueda(buscar);
	query = query.or(`busqueda_general.ilike.%${bNorm}%`);
}

if (ubicacion) {
	const uNorm = normalizarBusqueda(ubicacion);
	query = query.or(`busqueda_ubicacion.ilike.%${uNorm}%`);
}

const { data: personas, error: fetchError } = await query;

// Preparar los marcadores para el mapa
const markerItems = (personas || []).map((p) => ({
	id: p.id,
	latitud: p.latitud ? parseFloat(p.latitud.toString()) : (COORDENADAS_ESTADOS[p.estado] ? COORDENADAS_ESTADOS[p.estado][0] + (Math.random() - 0.5) * 0.05 : null),
	longitud: p.longitud ? parseFloat(p.longitud.toString()) : (COORDENADAS_ESTADOS[p.estado] ? COORDENADAS_ESTADOS[p.estado][1] + (Math.random() - 0.5) * 0.05 : null),
	titulo: p.nombre_completo,
	subtitulo: `${p.ciudad_municipio}, ${p.estado}`,
	descripcion: p.vestimenta_rasgos || "",
	badge: p.tipo_reporte,
	badgeType:
		p.tipo_reporte === "BUSCO" ? ("danger" as const) : ("success" as const),
	contacto: p.contacto_reportante,
	imagen_url: p.imagen_url,
}));
---

<Layout title="Personas Desaparecidas">
	<div style="margin-bottom: 20px;">
		<a href="/" style="text-decoration: none; color: var(--accent);"
			>← Volver al Inicio</a
		>
	</div>

	<h1 style="margin-bottom: 10px;" data-i18n="personas.title">Búsqueda y Reencuentro</h1>
	<p style="margin-bottom: 20px; color: #555;" data-i18n="personas.subtitle">
		Si no logras contactar a un ser querido o si estás a salvo y quieres
		avisarlo, por favor llena un reporte. Cada dato cuenta para unir
		familias. Todos los campos marcados con * son obligatorios.
	</p>

	{
		mensaje && (
			<div
				class="card"
				style={`background-color: ${mensajeTipo === "success" ? "#c8e6c9" : "#ffcdd2"}; border-color: ${mensajeTipo === "success" ? "#81c784" : "#e57373"};`}
			>
				<strong>
					{mensajeTipo === "success" ? "Éxito:" : "Error:"}
				</strong>{" "}
				{mensaje}
			</div>
		)
	}

	<details
		style="margin-bottom: 30px; border: 2px solid var(--primary-blue); background-color: #f0f7ff; padding: 24px; border-radius: 8px; box-shadow: 0 4px 12px rgba(0, 91, 181, 0.08);"
	>
		<summary
			class="btn"
			style="display: flex; justify-content: center; align-items: center; gap: 10px; margin: 0 auto; max-width: 550px; font-size: 1.2rem; cursor: pointer; border: none; outline: none; box-shadow: 0 4px 10px rgba(0, 91, 181, 0.25);"
		>
			🔍 Buscar Persona / Reportar que estás a Salvo
		</summary>

		<div
			style="margin-top: 24px; background: #ffffff; padding: 20px; border-radius: 6px; border: 1px solid var(--border-color);"
		>
			<form method="POST">
				<div class="form-group">
					<label>Tipo de Reporte *</label>
					<select name="tipo_reporte" required>
						<option value="BUSCO"
							>Busco a un familiar / amigo</option
						>
						<option value="ENCONTRADO"
							>Estoy a salvo / Encontré a alguien</option
						>
					</select>
				</div>

				<div class="form-group">
					<label>Nombre y Apellido *</label>
					<input
						type="text"
						name="nombre_completo"
						placeholder="Ej: Juan Pérez"
						required
					/>
				</div>

				<div style="display: flex; gap: 10px; flex-wrap: wrap;">
					<div class="form-group" style="flex: 1; min-width: 150px;">
						<label>Estado *</label>
						<select
							name="estado"
							class="estado-select"
							required
						>
							<option value="">Selecciona un estado</option>
							{ESTADOS.map((e) => <option value={e}>{e}</option>)}
						</select>
					</div>
					<div class="form-group" style="flex: 1; min-width: 150px;">
						<label>Ciudad / Municipio *</label>
						<select
							name="ciudad_municipio"
							class="ciudad-select"
							required
						>
							<option value="">Primero selecciona un estado</option>
						</select>
					</div>
				</div>

				<div class="form-group">
					<label>Dirección o Referencia de último paradero</label>
					<input
						type="text"
						name="direccion_referencia"
						placeholder="Ej: Cerca de la plaza, edif. azul"
					/>
				</div>

				<div class="form-group">
					<label>Rasgos Físicos y Vestimenta</label>
					<textarea
						name="vestimenta_rasgos"
						placeholder="Ej: Franela roja, jeans, cicatriz en la mano derecha. Edad aprox 40 años."
					></textarea>
				</div>

				<div class="form-group">
					<label>Estado Vital *</label>
					<select name="estado_vital" required>
						<option value="DESAPARECIDO"
							>Desaparecido / Sin contacto</option
						>
						<option value="A SALVO">A salvo / Ileso</option>
						<option value="HOSPITALIZADO"
							>Hospitalizado / Herido</option
						>
					</select>
				</div>

				<div class="form-group">
					<label>Tu información de contacto *</label>
					<input
						type="text"
						name="contacto_reportante"
						placeholder="Ej: WhatsApp +58..., Telegram @usuario"
						required
					/>
					<small style="color: #666;"
						>No lo publiques si crees que es riesgoso, usa Telegram
						si es posible.</small
					>
				</div>

				<div
					style="display: flex; gap: 10px; flex-wrap: wrap; align-items: flex-end;"
					class="form-group"
				>
					<div style="flex: 1; min-width: 200px;">
						<label
							>Coordenadas GPS (Recomendado para el Mapa
							interactivo)</label
						>
						<div style="display: flex; gap: 8px;">
							<input
								type="text"
								id="input-lat"
								name="latitud"
								placeholder="Latitud (Ej: 10.496)"
								readonly
								style="background: var(--bg-gray); cursor: not-allowed;"
							/>
							<input
								type="text"
								id="input-lon"
								name="longitud"
								placeholder="Longitud (Ej: -66.879)"
								readonly
								style="background: var(--bg-gray); cursor: not-allowed;"
							/>
						</div>
					</div>
					<button
						type="button"
						id="btn-gps"
						class="btn btn-secondary"
						style="height: 48px; padding: 0 15px; font-size: 0.9rem; white-space: nowrap;"
					>
						📍 Capturar GPS
					</button>
				</div>
				<div
					style="font-size: 0.85rem; color: #444; margin-top: -10px; margin-bottom: 5px; line-height: 1.4;"
				>
					<strong>🔒 Privacidad y utilidad:</strong> Tu navegador te pedirá
					permiso (es totalmente seguro). Tu ubicación ayuda a que los vecinos
					que estén cerca puedan encontrar esta información fácilmente en
					el mapa interactivo. ¡Por favor, apruébalo!
				</div>
				<div
					id="gps-status"
					style="font-size: 0.85rem; color: #555; margin-bottom: 15px;"
				>
				</div>

				<div class="form-group">
					<label
						>Foto de la Persona (Opcional - Se comprime
						automáticamente)</label
					>
					<input
						type="file"
						id="image-file"
						accept="image/*"
						style="border: 2px solid var(--border-color); padding: 8px; width: 100%; border-radius: 6px; font-size: 0.95rem;"
					/>
					<input
						type="hidden"
						name="imagen_url"
						id="input-imagen-url"
					/>
					<div
						id="upload-status"
						style="font-size: 0.85rem; color: #555; margin-top: 5px;"
					>
					</div>
				</div>

				<button type="submit">Enviar Reporte</button>
			</form>
		</div>
	</details>

	<hr
		style="border: 0; border-top: 1px solid var(--border-color); margin: 30px 0;"
	/>

	<h2>Listado de Búsqueda</h2>
	<form
		method="GET"
		style="background: none; border: none; padding: 0; margin-top: 10px; margin-bottom: 20px; display: flex; flex-wrap: wrap; gap: 10px;"
	>
		<input
			type="text"
			name="q"
			placeholder="Buscar por nombre..."
			value={buscar}
			style="flex: 2; min-width: 150px;"
		/>
		<input
			type="text"
			name="ubicacion"
			placeholder="📍 Ciudad o Estado..."
			value={ubicacion}
			style="flex: 1; min-width: 150px;"
		/>
		<button type="submit" style="width: auto;">Buscar</button>
		{
			(buscar || ubicacion) && (
				<a
					href="/personas"
					class="btn btn-secondary"
					style="width: auto;"
				>
					Limpiar
				</a>
			)
		}
	</form>

	<!-- Filtros de estado -->
	<div style="display: flex; gap: 10px; margin-bottom: 20px; flex-wrap: wrap;">
		<a href={`/personas?q=${buscar}&ubicacion=${ubicacion}`}
			class="btn btn-secondary"
			style={`width: auto; padding: 6px 14px; font-size: 0.9rem; ${!filtroEstado ? 'background-color: var(--primary-blue); color: white;' : ''}`}
		>Todos</a>
		<a href={`/personas?q=${buscar}&ubicacion=${ubicacion}&estado_vital=DESAPARECIDO`}
			class="btn btn-secondary"
			style={`width: auto; padding: 6px 14px; font-size: 0.9rem; ${filtroEstado === 'DESAPARECIDO' ? 'background-color: #b91c1c; color: white; border-color: #b91c1c;' : ''}`}
		><span style="display:inline-block; width:8px; height:8px; background:#ef4444; border-radius:50%; margin-right:5px;"></span>Sin contacto</a>
		<a href={`/personas?q=${buscar}&ubicacion=${ubicacion}&estado_vital=A SALVO`}
			class="btn btn-secondary"
			style={`width: auto; padding: 6px 14px; font-size: 0.9rem; ${filtroEstado === 'A SALVO' ? 'background-color: #166534; color: white; border-color: #166534;' : ''}`}
		><span style="display:inline-block; width:8px; height:8px; background:#22c55e; border-radius:50%; margin-right:5px;"></span>Localizados</a>
	</div>

	<div style="margin-bottom: 25px;">
		<MapaInteractivo items={markerItems} mapId="mapa-personas" />
	</div>

	<div class="lista">
		{fetchError && <p>Error al cargar los datos: {fetchError.message}</p>}

		{
			(!personas || personas.length === 0) && !fetchError && (
				<p>No hay reportes activos en este momento.</p>
			)
		}

		{
			personas &&
				personas.map((persona) => (
					<div class={`card ${persona.estado_vital === 'A SALVO' ? 'card-resolved' : ''}`} data-token={persona.token_edicion || ''} data-id={persona.id} data-estado-vital={persona.estado_vital} style={persona.estado_vital === 'A SALVO' ? 'opacity: 0.65; border-left: 4px solid #22c55e;' : 'border-left: 4px solid #ef4444;'}>
						<div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px;">
							<h3 style="margin: 0; font-size: 1.2rem;">
								{persona.nombre_completo}
							</h3>
							<span
								class={`badge ${persona.estado_vital === 'A SALVO' ? 'badge-success' : 'badge-danger'}`}
							>
								{persona.estado_vital === 'A SALVO' ? '✅ Localizado' : '🔴 Sin contacto'}
							</span>
						</div>

						{persona.imagen_url && (
							<details style="margin-bottom: 12px; max-width: 100%; border: none; padding: 0; background: transparent;">
								<summary
									class="btn btn-secondary"
									style="padding: 6px 12px; font-size: 0.85rem; display: inline-block; margin-bottom: 8px;"
								>
									📷 Ver Foto
								</summary>
								<img
									src={optimizarImagen(persona.imagen_url)}
									alt={`Foto de ${persona.nombre_completo}`}
									class="img-zoomable"
									style="max-width: 100%; max-height: 250px; border-radius: 6px; object-fit: cover; border: 2px solid var(--border-color); display: block;"
								/>
							</details>
						)}

						<p style="margin-bottom: 5px; font-size: 0.95rem;">
							<strong>📍 Ubicación:</strong>{" "}
							{persona.ciudad_municipio}, {persona.estado}
							{persona.direccion_referencia &&
								` (${persona.direccion_referencia})`}
						</p>

						{persona.vestimenta_rasgos && (
							<p style="margin-bottom: 5px; font-size: 0.95rem;">
								<strong>👤 Rasgos:</strong>{" "}
								{persona.vestimenta_rasgos}
							</p>
						)}

						<div style="display: flex; gap: 10px; margin-top: 12px; font-size: 0.9rem; flex-wrap: wrap;">
							<span style={`background: ${persona.estado_vital === 'A SALVO' ? '#dcfce3' : '#fee2e2'}; color: ${persona.estado_vital === 'A SALVO' ? '#166534' : '#b91c1c'}; padding: 3px 8px; border-radius: 4px; font-weight: 600;`}>
								{persona.estado_vital}
							</span>
							<span style="background: #eee; padding: 3px 8px; border-radius: 4px;">
								Contacto:{" "}
								<strong>{persona.contacto_reportante}</strong>
							</span>
						</div>

						<!-- Botón owner: se muestra via JS si el token coincide con localStorage -->
						{persona.estado_vital !== 'A SALVO' && (
							<form method="POST" class="owner-actions" style="display: none; margin-top: 15px; padding-top: 15px; border-top: 1px dashed var(--border-color);">
								<input type="hidden" name="action" value="marcar_localizado" />
								<input type="hidden" name="id" value={persona.id} />
								<input type="hidden" name="token_edicion" value={persona.token_edicion} />
								<button type="submit" style="width: 100%; padding: 10px; background: #166534; color: white;">✅ Marcar como Localizado / A Salvo</button>
							</form>
						)}

						<!-- Botones públicos y de contacto -->
						{persona.estado_vital !== 'A SALVO' && persona.contacto_reportante && (
							<div style="margin-top: 12px; padding-top: 10px; border-top: 1px dashed var(--border-color);">
								<span style="display: block; font-size: 0.8rem; color: #555; margin-bottom: 6px; font-weight: 600;">¿Tienes información sobre esta persona?</span>
								<a href={`https://wa.me/?text=${encodeURIComponent(`Hola, tengo información sobre ${persona.nombre_completo} que fue reportado/a como desaparecido/a en ${persona.ciudad_municipio}, ${persona.estado}. Contacto del familiar: ${persona.contacto_reportante}`)}`}
									target="_blank" rel="noopener"
									class="btn btn-secondary" style="padding: 6px 12px; font-size: 0.85rem; width: auto; display: inline-flex; align-items: center; gap: 4px; text-decoration: none;"
								>💬 Tengo información</a>
							</div>
						)}

						<!-- Compartir -->
						<div style="margin-top: 12px; padding-top: 10px; border-top: 1px dashed var(--border-color);">
							<span style="display: block; font-size: 0.8rem; color: #555; margin-bottom: 6px; font-weight: 600;">📣 Compartir esta ficha:</span>
							<div style="display: flex; gap: 8px; flex-wrap: wrap;">
								<a href={`https://wa.me/?text=${encodeURIComponent(`Se busca a ${persona.nombre_completo}. Última ubicación: ${persona.ciudad_municipio}, ${persona.estado}. Si la/lo has visto, contactar a: ${persona.contacto_reportante}`)}`}
									target="_blank" rel="noopener"
									style="background: #25D366; color: white; padding: 6px 12px; border-radius: 4px; font-size: 0.85rem; text-decoration: none; font-weight: 600; display: inline-flex; align-items: center; gap: 6px;"
								>
