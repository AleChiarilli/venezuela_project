---
// src/layouts/Layout.astro
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content="Apoyo Vzla - Plataforma de apoyo comunitario en emergencias." />
		<title>{title} | Apoyo Vzla</title>
	</head>
	<body>
		<div class="vzla-stripe"></div>
		<header class="main-header">
			<div class="container">
				<a href="/" class="logo"><strong>Apoyo</strong>Vzla</a>
				<nav>
					<a href="/personas">Personas</a>
					<a href="/suministros">Ayuda y Comida</a>
					<a href="/refugios">Refugios</a>
				</nav>
			</div>
		</header>

		<main class="container">
			<slot />
		</main>

		<footer>
			<div class="container text-center" style="max-width: 800px;">
				<p style="margin-bottom: 15px; font-weight: 500;">Diseñado para situaciones de emergencia.<br/>Carga rápida, bajo consumo de datos.</p>
				
				<div style="background: #eef2f6; padding: 15px; border-radius: 8px; font-size: 0.85rem; color: #555; text-align: left; margin-bottom: 15px; border: 1px solid #d0e0f0;">
					<strong>📌 Aviso de Responsabilidad:</strong> ApoyoVzla es una herramienta cívica, gratuita y colaborativa para centralizar información en momentos críticos. La información publicada es reportada por la comunidad y no podemos verificar independientemente cada caso. Recomendamos siempre precaución y sentido común al acudir a lugares o concretar entregas.
				</div>

				<p style="font-size: 0.85rem;">
					Creado para sumar. Si tienes ideas de mejora, comentarios o quieres colaborar con el desarrollo, 
					puedes contactarme en Instagram/X: <strong>@AleChiarilli</strong> o aportar directamente en el <a href="https://github.com/AleChiarilli/venezuela_project" target="_blank" style="color: var(--primary-blue); text-decoration: underline;">repositorio de GitHub</a>.
				</p>
			</div>
		</footer>
	</body>
</html>

<style is:global>
	/* RESET & HIGH PERFORMANCE CSS */
	:root {
		--bg-color: #ffffff;
		--text-color: #1a1a1a;
		--primary-blue: #005bb5; /* Trustworthy, calm blue */
		--primary-blue-hover: #004488;
		--border-color: #e0e0e0;
		--bg-gray: #f5f5f5;
	}

	* { box-sizing: border-box; margin: 0; padding: 0; }

	/* SYSTEM FONTS ONLY FOR ZERO NETWORK OVERHEAD */
	body {
		font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
		background-color: var(--bg-color);
		color: var(--text-color);
		line-height: 1.6;
		font-size: 18px; /* Large text for readability */
		min-height: 100vh;
		display: flex;
		flex-direction: column;
	}

	.vzla-stripe {
		height: 6px;
		width: 100%;
		background: linear-gradient(to right, #FFCC00 33.33%, #00247D 33.33%, #00247D 66.66%, #CF142B 66.66%);
	}

	.container {
		width: 100%;
		max-width: 1200px; /* Use more screen space on desktop */
		margin: 0 auto;
		padding: 20px;
	}

	/* HEADER & NAV */
	.main-header {
		background-color: #ffffff;
		border-bottom: 2px solid var(--border-color);
	}
	.main-header .container {
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		gap: 15px;
		padding: 15px 20px;
	}
	.logo { 
		color: var(--text-color); 
		text-decoration: none; 
		font-size: 1.5rem; 
		letter-spacing: -0.5px;
	}
	.logo strong { color: var(--primary-blue); }
	
	nav { display: flex; gap: 15px; flex-wrap: wrap; }
	nav a { 
		color: #555; 
		text-decoration: none; 
		font-size: 1rem; 
		font-weight: 500;
	}
	nav a:hover, nav a:active { color: var(--primary-blue); text-decoration: underline; }

	main { flex: 1; }

	/* HIGH CONTRAST CARDS & FORMS */
	.card {
		background: #ffffff;
		border: 2px solid var(--border-color);
		padding: 24px;
		margin-bottom: 20px;
		border-radius: 8px;
		text-decoration: none;
		color: inherit;
		display: block;
		transition: border-color 0.2s ease, background-color 0.2s ease, transform 0.2s ease;
	}

	.card:active, .card:hover {
		border-color: var(--primary-blue);
		background-color: #f8fbff;
		transform: translateY(-2px);
	}

	/* Botones Modernos y Optimizados */
	button, .btn {
		background-color: var(--primary-blue);
		color: #ffffff;
		border: none;
		padding: 14px 24px;
		font-size: 1.05rem;
		font-weight: 600;
		border-radius: 6px;
		cursor: pointer;
		display: inline-block;
		text-align: center;
		text-decoration: none;
		transition: background-color 0.2s ease, box-shadow 0.2s ease;
		box-shadow: 0 2px 4px rgba(0, 91, 181, 0.2);
	}
	button:hover, .btn:hover {
		background-color: var(--primary-blue-hover);
		box-shadow: 0 4px 8px rgba(0, 91, 181, 0.3);
	}
	button:active, .btn:active {
		transform: translateY(1px);
		box-shadow: none;
	}
	
	.btn-secondary {
		background-color: #ffffff;
		color: var(--primary-blue);
		border: 2px solid var(--primary-blue);
		box-shadow: none;
	}
	.btn-secondary:hover {
		background-color: #f0f7ff;
		box-shadow: none;
	}

	/* Formularios */
	.form-group { margin-bottom: 18px; }
	label { display: block; font-weight: 600; margin-bottom: 6px; color: #333; }
	input[type="text"], input[type="tel"], select, textarea {
		width: 100%;
		padding: 12px;
		border: 2px solid var(--border-color);
		border-radius: 6px;
		font-family: inherit;
		font-size: 1rem;
		transition: border-color 0.2s ease;
	}
	input[type="text"]:focus, input[type="tel"]:focus, select:focus, textarea:focus {
		outline: none;
		border-color: var(--primary-blue);
	}
	textarea { resize: vertical; min-height: 100px; }
	
	/* Detalles y Summary */
	details {
		background: #ffffff;
		border: 1px solid var(--border-color);
		border-radius: 8px;
		padding: 16px;
	}
	summary {
		list-style: none;
		cursor: pointer;
	}
	summary::-webkit-details-marker {
		display: none;
	}

	/* Badges & Etiquetas */
	.badge {
		display: inline-block;
		padding: 4px 8px;
		font-size: 0.8rem;
		font-weight: 700;
		border-radius: 4px;
		text-transform: uppercase;
		letter-spacing: 0.5px;
	}
	.badge-danger { background: #fee2e2; color: #b91c1c; }
	.badge-success { background: #dcfce3; color: #166534; }
	.badge-warning { background: #fef3c7; color: #b45309; }
	.badge-neutral { background: #f1f5f9; color: #475569; }

	h1, h2, h3 { line-height: 1.2; color: #000; margin-bottom: 12px; }

	p { margin-bottom: 16px; color: #333; }

	footer { 
		margin-top: auto; 
		padding: 30px 0; 
		background: var(--bg-gray);
		border-top: 1px solid var(--border-color); 
		font-size: 0.9rem; 
		color: #666; 
	}
	.text-center { text-align: center; }

	@media (max-width: 480px) {
		.main-header .container { flex-direction: column; text-align: center; }
		nav { width: 100%; justify-content: center; }
	}

	/* Sistema de Grid Responsivo para las Listas */
	.lista {
		display: grid;
		grid-template-columns: 1fr;
		gap: 20px;
	}
	@media (min-width: 768px) {
		.lista {
			grid-template-columns: repeat(2, 1fr);
		}
	}
	@media (min-width: 1024px) {
		.lista {
			grid-template-columns: repeat(3, 1fr);
		}
	}
</style>