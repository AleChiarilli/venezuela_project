---
// src/layouts/Layout.astro
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content="Apoyo Vzla - Plataforma de apoyo comunitario en emergencias." />
		<title>{title} | Apoyo Vzla</title>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="manifest" href="/manifest.webmanifest" />
		<script is:inline src="/registerSW.js"></script>
	</head>
	<body>
		<div class="vzla-stripe"></div>
		<header class="main-header">
			<div class="container">
				<a href="/" class="logo" style="display: flex; align-items: center; gap: 8px;">
					<svg width="26" height="26" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
						<clipPath id="circleView"><circle cx="50" cy="50" r="50"/></clipPath>
						<g clip-path="url(#circleView)">
							<rect x="0" y="0" width="100" height="33.33" fill="#FFCC00"/>
							<rect x="0" y="33.33" width="100" height="33.33" fill="#00247D"/>
							<rect x="0" y="66.66" width="100" height="33.34" fill="#CF142B"/>
						</g>
					</svg>
					<span><strong style="color: #D99000;">Apoyo</strong><span style="color: #00247D; font-weight: 800;">Vz</span><span style="color: #CF142B; font-weight: 800;">la</span></span>
				</a>
				<nav>
					<a href="/personas" data-i18n="nav.personas">Personas</a>
					<a href="/suministros" data-i18n="nav.suministros">Ayuda y Comida</a>
					<a href="/refugios" data-i18n="nav.refugios">Refugios</a>
					<a href="/puntos-donacion" data-i18n="nav.donaciones">Centros de Acopio</a>
				</nav>
				<div class="header-actions">
					<div class="lang-toggle" id="lang-toggle" title="Cambiar idioma / Switch language">
						<span class="lang-option active" data-lang="es">ES</span>
						<span class="lang-option" data-lang="en">EN</span>
					</div>
					<a
						href="https://donate.stripe.com/8x27sLbn06OwfTs8FzcAo0W"
						target="_blank"
						rel="noopener noreferrer"
						class="btn-donate"
						id="donate-btn"
						data-i18n="nav.donar"
					>
						❤️ Donar para Venezuela
					</a>
				</div>
			</div>
		</header>

		<main class="container">
			<div class="emergency-banner">
				<div class="emergency-banner-title">
					<span style="display:inline-block; width:8px; height:8px; background:red; border-radius:50%; margin-right:5px; animation: pulse 2s infinite;"></span>
					<span data-i18n="emergency.title">Teléfonos de emergencia (Nacionales)</span>
				</div>
				<div class="emergency-numbers">
					<a href="tel:911" class="emergency-number"><strong>911</strong><span>General / Movistar</span></a>
					<a href="tel:171" class="emergency-number"><strong>171</strong><span data-i18n="emergency.cantv">Fijo CANTV</span></a>
					<a href="tel:112" class="emergency-number"><strong>112</strong><span>Digitel</span></a>
					<a href="tel:*1" class="emergency-number"><strong>*1</strong><span>Movilnet</span></a>
				</div>
				<div style="margin-top: 15px; text-align: right;">
					<a href="/numeros-locales" style="font-size: 0.9rem; color: #c53030; font-weight: 600; text-decoration: none;" data-i18n="emergency.buscar">🔍 Buscar números locales o ➕ Agregar nuevo →</a>
				</div>
			</div>


			<slot />
		</main>

		<footer>
			<div class="container text-center" style="max-width: 700px;">
				<p style="font-size: 0.9rem; color: #444; margin-bottom: 10px; font-weight: 500;" data-i18n="footer.tagline">
					⚡ Diseñado para emergencias · Carga rápida · Bajo consumo de datos
				</p>
				<p style="font-size: 0.82rem; color: #666; margin-bottom: 12px; line-height: 1.6;" data-i18n-html="footer.disclaimer">
					Herramienta cívica y gratuita. La información es reportada por la comunidad — te recomendamos confirmar por teléfono o mensaje antes de acudir a cualquier lugar.
					Ideas o mejoras: <a href="mailto:hola@theeclatmethod.com" style="color: var(--primary-blue); font-weight: 600;">hola@theeclatmethod.com</a>
				</p>
				<p style="font-size: 0.8rem; color: #888;" data-i18n-html="footer.opensource">
					🌍 Código abierto y transparente ·
					<a href="https://github.com/AleChiarilli/venezuela_project" target="_blank" rel="noopener noreferrer" style="color: var(--primary-blue); font-weight: 600;">Ver repositorio en GitHub</a>
				</p>
			</div>
		</footer>

		<!-- Lightbox Modal -->
		<div id="lightbox-modal" class="lightbox-modal">
			<span class="lightbox-close">&times;</span>
			<img class="lightbox-content" id="lightbox-img">
		</div>

		<script is:inline>
			// ===== i18n Translation System =====
			var I18N = {
				en: {
					// Nav
					"nav.personas": "People",
					"nav.suministros": "Aid & Food",
					"nav.refugios": "Shelters",
					"nav.donaciones": "Collection Points",
					"nav.donar": "❤️ Donate for Venezuela",
					// Emergency banner
					"emergency.title": "Emergency phones (National)",
					"emergency.cantv": "Landline CANTV",
					"emergency.buscar": "🔍 Search local numbers or ➕ Add new →",
					// Footer
					"footer.tagline": "⚡ Built for emergencies · Fast loading · Low data usage",
					"footer.disclaimer": 'Free civic tool. Information is community-reported — we recommend confirming by phone or message before going to any location. Ideas or improvements: <a href="mailto:hola@theeclatmethod.com" style="color: var(--primary-blue); font-weight: 600;">hola@theeclatmethod.com</a>',
					"footer.opensource": '🌍 Open source and transparent · <a href="https://github.com/AleChiarilli/venezuela_project" target="_blank" rel="noopener noreferrer" style="color: var(--primary-blue); font-weight: 600;">View repository on GitHub</a>',
					// Index page
					"index.title": "Active Solidarity Network",
					"index.lead": "In difficult times, our greatest strength is each other. This platform lets you request urgent help or lend a hand to those in need. Select an option to get started.",
					"index.personas.title": "People",
					"index.personas.desc": "Report a missing family member or let others know if you've found someone.",
					"index.personas.link": "Go here →",
					"index.suministros.title": "Aid & Food",
					"index.suministros.desc": "Offer or request food, water, medicine, generators, transport and other neighborhood support.",
					"index.suministros.link": "Go here →",
					"index.refugios.title": "Shelters",
					"index.refugios.desc": "Find a safe place to sleep or report if you have space available to shelter others.",
					"index.refugios.link": "Go here →",
					"index.donaciones.title": "Collection Points",
					"index.donaciones.desc": "Find or register physical humanitarian aid collection points around the world.",
					"index.donaciones.link": "Go here →",
					// Personas page
					"personas.title": "Search & Reunion",
					"personas.subtitle": "If you can't reach a loved one or if you're safe and want to let them know, please fill out a report. Every detail counts to reunite families. All fields marked with * are required.",
					// Suministros page
					"suministros.title": "Aid & Food",
					"suministros.subtitle": "Solidarity keeps us afloat. Do you have extra water or food? Can you offer transport, medical assistance, or lend a generator? Offer your help — your time and resources are worth gold. All fields with * are required.",
					// Refugios page
					"refugios.title": "Shelters & Safe Housing",
					"refugios.subtitle": "No Venezuelan should spend the night out in the open. Do you have a spare room or a safe roof? Help someone who has nowhere to stay tonight. Your hospitality can save lives. All fields with * are required.",
					// Puntos donacion page
					"donacion.title": "Humanitarian Collection Points (Acopio)",
					"donacion.subtitle": "Find or register collection points anywhere in the world. Help channel supplies and donations to those who need them most in Venezuela. All fields with * are required."
				},
				es: {
					// Nav
					"nav.personas": "Personas",
					"nav.suministros": "Ayuda y Comida",
					"nav.refugios": "Refugios",
					"nav.donaciones": "Centros de Acopio",
					"nav.donar": "❤️ Donar para Venezuela",
					// Emergency banner
					"emergency.title": "Teléfonos de emergencia (Nacionales)",
					"emergency.cantv": "Fijo CANTV",
					"emergency.buscar": "🔍 Buscar números locales o ➕ Agregar nuevo →",
					// Footer
					"footer.tagline": "⚡ Diseñado para emergencias · Carga rápida · Bajo consumo de datos",
					"footer.disclaimer": 'Herramienta cívica y gratuita. La información es reportada por la comunidad — te recomendamos confirmar por teléfono o mensaje antes de acudir a cualquier lugar. Ideas o mejoras: <a href="mailto:hola@theeclatmethod.com" style="color: var(--primary-blue); font-weight: 600;">hola@theeclatmethod.com</a>',
					"footer.opensource": '🌍 Código abierto y transparente · <a href="https://github.com/AleChiarilli/venezuela_project" target="_blank" rel="noopener noreferrer" style="color: var(--primary-blue); font-weight: 600;">Ver repositorio en GitHub</a>',
					// Index page
					"index.title": "Red de Solidaridad Activa",
					"index.lead": "En momentos difíciles, nuestra mayor fuerza somos nosotros mismos. Esta plataforma te permite pedir ayuda urgente o extender tu mano a quien lo necesita. Selecciona una opción para comenzar.",
					"index.personas.title": "Personas",
					"index.personas.desc": "Reporta a un familiar desaparecido o informa si has encontrado a alguien.",
					"index.personas.link": "Entrar aquí →",
					"index.suministros.title": "Ayuda y Comida",
					"index.suministros.desc": "Ofrece o solicita comida, agua, medicamentos, generadores eléctricos, transporte y otros apoyos vecinales.",
					"index.suministros.link": "Entrar aquí →",
					"index.refugios.title": "Refugios",
					"index.refugios.desc": "Encuentra un lugar seguro para dormir o reporta si tienes un espacio disponible para alojar a otros.",
					"index.refugios.link": "Entrar aquí →",
					"index.donaciones.title": "Centros de Acopio",
					"index.donaciones.desc": "Encuentra o registra puntos físicos de recolección de ayuda humanitaria e insumos alrededor del mundo.",
					"index.donaciones.link": "Entrar aquí →",
					// Personas page
					"personas.title": "Búsqueda y Reencuentro",
					"personas.subtitle": "Si no logras contactar a un ser querido o si estás a salvo y quieres avisarlo, por favor llena un reporte. Cada dato cuenta para unir familias. Todos los campos marcados con * son obligatorios.",
					// Suministros page
					"suministros.title": "Ayuda y Comida",
					"suministros.subtitle": "La solidaridad nos mantiene a flote. ¿Tienes agua o comida extra? ¿Puedes ofrecer transporte, asistencia médica o prestar un generador eléctrico? Ofrece tu ayuda, tu tiempo y recursos valen oro. Todos los campos con * son obligatorios.",
					// Refugios page
					"refugios.title": "Refugios y Techo Seguro",
					"refugios.subtitle": "Ningún venezolano debería pasar la noche a la intemperie. ¿Tienes una habitación desocupada o un techo seguro? Ayuda a alguien que no tenga dónde pasar la noche. Tu hospitalidad puede salvar vidas. Todos los campos con * son obligatorios.",
					// Puntos donacion page
					"donacion.title": "Centros de Acopio y Recolección Humanitaria",
					"donacion.subtitle": "Encuentra o registra puntos de recolección en cualquier parte del mundo. Ayuda a canalizar los insumos y donaciones hacia quienes más lo necesitan en Venezuela. Todos los campos con * son obligatorios."
				}
			};

			function applyLanguage(lang) {
				var dict = I18N[lang];
				if (!dict) return;

				// Update text-only elements
				document.querySelectorAll('[data-i18n]').forEach(function(el) {
					var key = el.getAttribute('data-i18n');
					if (dict[key]) el.textContent = dict[key];
				});

				// Update elements with HTML content (links inside text)
				document.querySelectorAll('[data-i18n-html]').forEach(function(el) {
					var key = el.getAttribute('data-i18n-html');
					if (dict[key]) el.innerHTML = dict[key];
				});

				// Update <html lang>
				document.documentElement.lang = lang;

				// Update toggle UI
				document.querySelectorAll('.lang-option').forEach(function(opt) {
					opt.classList.toggle('active', opt.getAttribute('data-lang') === lang);
				});

				// Persist
				try { localStorage.setItem('apoyovzla-lang', lang); } catch(e) {}
			}

			document.addEventListener("DOMContentLoaded", function() {
				// Lightbox
				var modal = document.getElementById("lightbox-modal");
				var modalImg = document.getElementById("lightbox-img");
				var closeBtn = document.querySelector(".lightbox-close");

				document.body.addEventListener("click", function(e) {
					if (e.target && e.target.classList.contains("img-zoomable")) {
						modal.style.display = "flex";
						modalImg.src = e.target.src;
						document.body.style.overflow = "hidden";
					}
				});

				closeBtn.onclick = function() {
					modal.style.display = "none";
					document.body.style.overflow = "auto";
				}

				modal.onclick = function(e) {
					if (e.target !== modalImg) {
						modal.style.display = "none";
						document.body.style.overflow = "auto";
					}
				}

				// Language toggle
				var toggle = document.getElementById('lang-toggle');
				if (toggle) {
					toggle.addEventListener('click', function(e) {
						var opt = e.target.closest('.lang-option');
						if (!opt) return;
						var lang = opt.getAttribute('data-lang');
						applyLanguage(lang);
					});
				}

				// Restore saved language
				try {
					var saved = localStorage.getItem('apoyovzla-lang');
					if (saved && saved !== 'es') applyLanguage(saved);
				} catch(e) {}
			});
		</script>
	</body>
</html>

<style is:global>
	/* RESET & HIGH PERFORMANCE CSS */
	:root {
		--bg-color: #ffffff;
		--text-color: #1a1a1a;
		--primary-blue: #005bb5; /* Trustworthy, calm blue */
		--primary-blue-hover: #004488;
		--border-color: #e0e0e0;
		--bg-gray: #f5f5f5;
	}

	* { box-sizing: border-box; margin: 0; padding: 0; }

	/* SYSTEM FONTS ONLY FOR ZERO NETWORK OVERHEAD */
	body {
		font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
		background-color: var(--bg-color);
		color: var(--text-color);
		line-height: 1.6;
		font-size: 18px; /* Large text for readability */
		min-height: 100vh;
		display: flex;
		flex-direction: column;
	}

	.vzla-stripe {
		height: 6px;
		width: 100%;
		background: linear-gradient(to right, #FFCC00 33.33%, #00247D 33.33%, #00247D 66.66%, #CF142B 66.66%);
	}

	.container {
		width: 100%;
		max-width: 1200px; /* Use more screen space on desktop */
		margin: 0 auto;
		padding: 20px;
	}

	/* HEADER & NAV */
	.main-header {
		background-color: #ffffff;
		border-bottom: 2px solid var(--border-color);
	}
	.main-header .container {
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		gap: 15px;
		padding: 15px 20px;
	}
	.logo { 
		color: var(--text-color); 
		text-decoration: none; 
		font-size: 1.5rem; 
		letter-spacing: -0.5px;
	}
	.logo strong { color: var(--primary-blue); }
	
	nav { display: flex; gap: 15px; flex-wrap: wrap; align-items: center; }
	nav a { 
		color: #555; 
		text-decoration: none; 
		font-size: 1rem; 
		font-weight: 500;
	}
	nav a:hover, nav a:active { color: var(--primary-blue); text-decoration: underline; }

	/* Donate CTA Button */
	.btn-donate {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		background: linear-gradient(135deg, #CF142B 0%, #e04040 50%, #D99000 100%);
		color: #ffffff;
		font-size: 0.95rem;
		font-weight: 700;
		padding: 10px 20px;
		border-radius: 50px;
		text-decoration: none;
		box-shadow: 0 2px 8px rgba(207, 20, 43, 0.35), 0 0 0 0 rgba(207, 20, 43, 0.4);
		transition: transform 0.2s ease, box-shadow 0.2s ease;
		animation: donate-pulse 2.5s ease-in-out infinite;
		white-space: nowrap;
		letter-spacing: 0.3px;
		flex-shrink: 0;
	}
	.btn-donate:hover {
		transform: translateY(-2px) scale(1.04);
		box-shadow: 0 4px 16px rgba(207, 20, 43, 0.45);
		animation: none;
	}
	.btn-donate:active {
		transform: translateY(0) scale(0.98);
		box-shadow: 0 1px 4px rgba(207, 20, 43, 0.3);
	}

	@keyframes donate-pulse {
		0%, 100% { box-shadow: 0 2px 8px rgba(207, 20, 43, 0.35), 0 0 0 0 rgba(207, 20, 43, 0.4); }
		50% { box-shadow: 0 2px 8px rgba(207, 20, 43, 0.35), 0 0 0 8px rgba(207, 20, 43, 0); }
	}

	main { flex: 1; }

	/* HIGH CONTRAST CARDS & FORMS */
	.card {
		background: #ffffff;
		border: 2px solid var(--border-color);
		padding: 24px;
		margin-bottom: 20px;
		border-radius: 8px;
		text-decoration: none;
		color: inherit;
		display: block;
		transition: border-color 0.2s ease, background-color 0.2s ease, transform 0.2s ease;
	}

	.card:active, .card:hover {
		border-color: var(--primary-blue);
		background-color: #f8fbff;
		transform: translateY(-2px);
	}

	/* Botones Modernos y Optimizados */
	button, .btn {
		background-color: var(--primary-blue);
		color: #ffffff;
		border: none;
		padding: 14px 24px;
		font-size: 1.05rem;
		font-weight: 600;
		border-radius: 6px;
		cursor: pointer;
		display: inline-block;
		text-align: center;
		text-decoration: none;
		transition: background-color 0.2s ease, box-shadow 0.2s ease;
		box-shadow: 0 2px 4px rgba(0, 91, 181, 0.2);
	}
	button:hover, .btn:hover {
		background-color: var(--primary-blue-hover);
		box-shadow: 0 4px 8px rgba(0, 91, 181, 0.3);
	}
	button:active, .btn:active {
		transform: translateY(1px);
		box-shadow: none;
	}
	
	.btn-secondary {
		background-color: #ffffff;
		color: var(--primary-blue);
		border: 2px solid var(--primary-blue);
		box-shadow: none;
	}
	.btn-secondary:hover {
		background-color: #f0f7ff;
		box-shadow: none;
	}

	/* Formularios */
	.form-group { margin-bottom: 18px; }
	label { display: block; font-weight: 600; margin-bottom: 6px; color: #333; }
	input[type="text"], input[type="tel"], select, textarea {
		width: 100%;
		padding: 12px;
		border: 2px solid var(--border-color);
		border-radius: 6px;
		font-family: inherit;
		font-size: 1rem;
		transition: border-color 0.2s ease;
	}
	input[type="text"]:focus, input[type="tel"]:focus, select:focus, textarea:focus {
		outline: none;
		border-color: var(--primary-blue);
	}
	textarea { resize: vertical; min-height: 100px; }
	
	/* Detalles y Summary */
	details {
		background: #ffffff;
		border: 1px solid var(--border-color);
		border-radius: 8px;
		padding: 16px;
	}
	summary {
		list-style: none;
		cursor: pointer;
	}
	summary::-webkit-details-marker {
		display: none;
	}

	/* Badges & Etiquetas */
	.badge {
		display: inline-block;
		padding: 4px 8px;
		font-size: 0.8rem;
		font-weight: 700;
		border-radius: 4px;
		text-transform: uppercase;
		letter-spacing: 0.5px;
	}
	.badge-danger { background: #fee2e2; color: #b91c1c; }
	.badge-success { background: #dcfce3; color: #166534; }
	.badge-warning { background: #fef3c7; color: #b45309; }
	.badge-neutral { background: #f1f5f9; color: #475569; }

	h1, h2, h3 { line-height: 1.2; color: #000; margin-bottom: 12px; }

	p { margin-bottom: 16px; color: #333; }

	footer { 
		margin-top: auto; 
		padding: 30px 0; 
		background: var(--bg-gray);
		border-top: 1px solid var(--border-color); 
		font-size: 0.9rem; 
		color: #666; 
	}
	.text-center { text-align: center; }

	/* Language Toggle */
	.header-actions {
		display: flex;
		align-items: center;
		gap: 12px;
		flex-shrink: 0;
	}
	.lang-toggle {
		display: flex;
		align-items: center;
		background: var(--bg-gray);
		border: 1px solid var(--border-color);
		border-radius: 20px;
		padding: 2px;
		cursor: pointer;
		user-select: none;
		flex-shrink: 0;
	}
	.lang-option {
		padding: 4px 10px;
		border-radius: 16px;
		font-size: 0.78rem;
		font-weight: 700;
		color: #888;
		transition: all 0.2s ease;
		letter-spacing: 0.5px;
	}
	.lang-option.active {
		background: var(--primary-blue);
		color: #fff;
		box-shadow: 0 1px 3px rgba(0,91,181,0.3);
	}
	.lang-option:hover:not(.active) {
		color: #333;
	}

	@media (max-width: 480px) {
		.main-header .container { flex-direction: column; text-align: center; }
		nav { width: 100%; justify-content: center; }
		.header-actions { width: 100%; justify-content: center; }
		.btn-donate { flex: 1; justify-content: center; font-size: 1rem; padding: 12px 20px; }
	}

	/* Sistema de Grid Responsivo para las Listas */
	.lista {
		display: grid;
		grid-template-columns: 1fr;
		gap: 20px;
	}
	@media (min-width: 768px) {
		.lista {
			grid-template-columns: repeat(2, 1fr);
		}
	}
	@media (min-width: 1024px) {
		.lista {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	/* Emergency Banner */
	.emergency-banner {
