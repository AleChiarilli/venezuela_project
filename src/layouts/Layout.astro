---
// src/layouts/Layout.astro
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content="Apoyo Vzla - Plataforma de apoyo comunitario en emergencias." />
		<title>{title} | Apoyo Vzla</title>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="manifest" href="/manifest.webmanifest" />
		<script is:inline src="/registerSW.js"></script>
	</head>
	<body>
		<div class="vzla-stripe"></div>
		<header class="main-header">
			<div class="container">
				<a href="/" class="logo" style="display: flex; align-items: center; gap: 8px;">
					<svg width="26" height="26" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
						<clipPath id="circleView"><circle cx="50" cy="50" r="50"/></clipPath>
						<g clip-path="url(#circleView)">
							<rect x="0" y="0" width="100" height="33.33" fill="#FFCC00"/>
							<rect x="0" y="33.33" width="100" height="33.33" fill="#00247D"/>
							<rect x="0" y="66.66" width="100" height="33.34" fill="#CF142B"/>
						</g>
					</svg>
					<span><strong style="color: #D99000;">Apoyo</strong><span style="color: #00247D; font-weight: 800;">Vz</span><span style="color: #CF142B; font-weight: 800;">la</span></span>
				</a>
				<nav>
					<a href="/personas">Personas</a>
					<a href="/suministros">Ayuda y Comida</a>
					<a href="/refugios">Refugios</a>
					<a href="/puntos-donacion">Donaciones</a>
				</nav>
			</div>
		</header>

		<main class="container">
			<div class="emergency-banner">
				<div class="emergency-banner-title">
					<span style="display:inline-block; width:8px; height:8px; background:red; border-radius:50%; margin-right:5px; animation: pulse 2s infinite;"></span>
					Teléfonos de emergencia (Nacionales)
				</div>
				<div class="emergency-numbers">
					<a href="tel:911" class="emergency-number"><strong>911</strong><span>General / Movistar</span></a>
					<a href="tel:171" class="emergency-number"><strong>171</strong><span>Fijo CANTV</span></a>
					<a href="tel:112" class="emergency-number"><strong>112</strong><span>Digitel</span></a>
					<a href="tel:*1" class="emergency-number"><strong>*1</strong><span>Movilnet</span></a>
				</div>
				<div style="margin-top: 15px; text-align: right;">
					<a href="/numeros-locales" style="font-size: 0.9rem; color: #c53030; font-weight: 600; text-decoration: none;">🔍 Buscar números locales o ➕ Agregar nuevo →</a>
				</div>
			</div>


			<slot />
		</main>

		<footer>
			<div class="container text-center" style="max-width: 700px;">
				<p style="font-size: 0.9rem; color: #444; margin-bottom: 10px; font-weight: 500;">
					⚡ Diseñado para emergencias · Carga rápida · Bajo consumo de datos
				</p>
				<p style="font-size: 0.82rem; color: #666; margin-bottom: 12px; line-height: 1.6;">
					Herramienta cívica y gratuita. La información es reportada por la comunidad — te recomendamos confirmar por teléfono o mensaje antes de acudir a cualquier lugar.
					Ideas o mejoras: <a href="mailto:hola@theeclatmethod.com" style="color: var(--primary-blue); font-weight: 600;">hola@theeclatmethod.com</a>
				</p>
				<p style="font-size: 0.8rem; color: #888;">
					🌍 Código abierto y transparente ·
					<a href="https://github.com/AleChiarilli/venezuela_project" target="_blank" rel="noopener noreferrer" style="color: var(--primary-blue); font-weight: 600;">Ver repositorio en GitHub</a>
				</p>
			</div>
		</footer>

		<!-- Lightbox Modal -->
		<div id="lightbox-modal" class="lightbox-modal">
			<span class="lightbox-close">&times;</span>
			<img class="lightbox-content" id="lightbox-img">
		</div>

		<script is:inline>
			document.addEventListener("DOMContentLoaded", function() {
				var modal = document.getElementById("lightbox-modal");
				var modalImg = document.getElementById("lightbox-img");
				var closeBtn = document.querySelector(".lightbox-close");

				document.body.addEventListener("click", function(e) {
					if (e.target && e.target.classList.contains("img-zoomable")) {
						modal.style.display = "flex";
						modalImg.src = e.target.src;
						document.body.style.overflow = "hidden";
					}
				});

				closeBtn.onclick = function() {
					modal.style.display = "none";
					document.body.style.overflow = "auto";
				}

				modal.onclick = function(e) {
					if (e.target !== modalImg) {
						modal.style.display = "none";
						document.body.style.overflow = "auto";
					}
				}
			});
		</script>
	</body>
</html>

<style is:global>
	/* RESET & HIGH PERFORMANCE CSS */
	:root {
		--bg-color: #ffffff;
		--text-color: #1a1a1a;
		--primary-blue: #005bb5; /* Trustworthy, calm blue */
		--primary-blue-hover: #004488;
		--border-color: #e0e0e0;
		--bg-gray: #f5f5f5;
	}

	* { box-sizing: border-box; margin: 0; padding: 0; }

	/* SYSTEM FONTS ONLY FOR ZERO NETWORK OVERHEAD */
	body {
		font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
		background-color: var(--bg-color);
		color: var(--text-color);
		line-height: 1.6;
		font-size: 18px; /* Large text for readability */
		min-height: 100vh;
		display: flex;
		flex-direction: column;
	}

	.vzla-stripe {
		height: 6px;
		width: 100%;
		background: linear-gradient(to right, #FFCC00 33.33%, #00247D 33.33%, #00247D 66.66%, #CF142B 66.66%);
	}

	.container {
		width: 100%;
		max-width: 1200px; /* Use more screen space on desktop */
		margin: 0 auto;
		padding: 20px;
	}

	/* HEADER & NAV */
	.main-header {
		background-color: #ffffff;
		border-bottom: 2px solid var(--border-color);
	}
	.main-header .container {
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		gap: 15px;
		padding: 15px 20px;
	}
	.logo { 
		color: var(--text-color); 
		text-decoration: none; 
		font-size: 1.5rem; 
		letter-spacing: -0.5px;
	}
	.logo strong { color: var(--primary-blue); }
	
	nav { display: flex; gap: 15px; flex-wrap: wrap; }
	nav a { 
		color: #555; 
		text-decoration: none; 
		font-size: 1rem; 
		font-weight: 500;
	}
	nav a:hover, nav a:active { color: var(--primary-blue); text-decoration: underline; }

	main { flex: 1; }

	/* HIGH CONTRAST CARDS & FORMS */
	.card {
		background: #ffffff;
		border: 2px solid var(--border-color);
		padding: 24px;
		margin-bottom: 20px;
		border-radius: 8px;
		text-decoration: none;
		color: inherit;
		display: block;
		transition: border-color 0.2s ease, background-color 0.2s ease, transform 0.2s ease;
	}

	.card:active, .card:hover {
		border-color: var(--primary-blue);
		background-color: #f8fbff;
		transform: translateY(-2px);
	}

	/* Botones Modernos y Optimizados */
	button, .btn {
		background-color: var(--primary-blue);
		color: #ffffff;
		border: none;
		padding: 14px 24px;
		font-size: 1.05rem;
		font-weight: 600;
		border-radius: 6px;
		cursor: pointer;
		display: inline-block;
		text-align: center;
		text-decoration: none;
		transition: background-color 0.2s ease, box-shadow 0.2s ease;
		box-shadow: 0 2px 4px rgba(0, 91, 181, 0.2);
	}
	button:hover, .btn:hover {
		background-color: var(--primary-blue-hover);
		box-shadow: 0 4px 8px rgba(0, 91, 181, 0.3);
	}
	button:active, .btn:active {
		transform: translateY(1px);
		box-shadow: none;
	}
	
	.btn-secondary {
		background-color: #ffffff;
		color: var(--primary-blue);
		border: 2px solid var(--primary-blue);
		box-shadow: none;
	}
	.btn-secondary:hover {
		background-color: #f0f7ff;
		box-shadow: none;
	}

	/* Formularios */
	.form-group { margin-bottom: 18px; }
	label { display: block; font-weight: 600; margin-bottom: 6px; color: #333; }
	input[type="text"], input[type="tel"], select, textarea {
		width: 100%;
		padding: 12px;
		border: 2px solid var(--border-color);
		border-radius: 6px;
		font-family: inherit;
		font-size: 1rem;
		transition: border-color 0.2s ease;
	}
	input[type="text"]:focus, input[type="tel"]:focus, select:focus, textarea:focus {
		outline: none;
		border-color: var(--primary-blue);
	}
	textarea { resize: vertical; min-height: 100px; }
	
	/* Detalles y Summary */
	details {
		background: #ffffff;
		border: 1px solid var(--border-color);
		border-radius: 8px;
		padding: 16px;
	}
	summary {
		list-style: none;
		cursor: pointer;
	}
	summary::-webkit-details-marker {
		display: none;
	}

	/* Badges & Etiquetas */
	.badge {
		display: inline-block;
		padding: 4px 8px;
		font-size: 0.8rem;
		font-weight: 700;
		border-radius: 4px;
		text-transform: uppercase;
		letter-spacing: 0.5px;
	}
	.badge-danger { background: #fee2e2; color: #b91c1c; }
	.badge-success { background: #dcfce3; color: #166534; }
	.badge-warning { background: #fef3c7; color: #b45309; }
	.badge-neutral { background: #f1f5f9; color: #475569; }

	h1, h2, h3 { line-height: 1.2; color: #000; margin-bottom: 12px; }

	p { margin-bottom: 16px; color: #333; }

	footer { 
		margin-top: auto; 
		padding: 30px 0; 
		background: var(--bg-gray);
		border-top: 1px solid var(--border-color); 
		font-size: 0.9rem; 
		color: #666; 
	}
	.text-center { text-align: center; }

	@media (max-width: 480px) {
		.main-header .container { flex-direction: column; text-align: center; }
		nav { width: 100%; justify-content: center; }
	}

	/* Sistema de Grid Responsivo para las Listas */
	.lista {
		display: grid;
		grid-template-columns: 1fr;
		gap: 20px;
	}
	@media (min-width: 768px) {
		.lista {
			grid-template-columns: repeat(2, 1fr);
		}
	}
	@media (min-width: 1024px) {
		.lista {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	/* Emergency Banner */
	.emergency-banner {
		background: #fff5f5;
		border: 1px solid #fed7d7;
		border-radius: 8px;
		padding: 15px;
		margin-bottom: 20px;
	}
	.emergency-banner-title {
		font-size: 0.85rem;
		font-weight: bold;
		color: #c53030;
		margin-bottom: 10px;
		text-transform: uppercase;
		letter-spacing: 0.5px;
		display: flex;
		align-items: center;
	}
	.emergency-numbers {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
	}
	.emergency-number {
		background: #fff;
		border: 1px solid #fed7d7;
		padding: 8px 12px;
		border-radius: 6px;
		text-decoration: none;
		color: #1a202c;
		display: flex;
		flex-direction: column;
		flex: 1;
		min-width: 120px;
		transition: background 0.2s;
	}
	.emergency-number:hover {
		background: #fff0f0;
	}
	.emergency-number strong {
		font-size: 1.2rem;
		color: #c53030;
	}
	.emergency-number span {
		font-size: 0.75rem;
		color: #718096;
	}

	@keyframes pulse {
		0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(229, 62, 62, 0.7); }
		70% { transform: scale(1); box-shadow: 0 0 0 6px rgba(229, 62, 62, 0); }
		100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(229, 62, 62, 0); }
	}

	/* Lightbox */
	.lightbox-modal {
		display: none;
		position: fixed;
		z-index: 9999;
		left: 0;
		top: 0;
		width: 100%;
		height: 100%;
		background-color: rgba(0, 0, 0, 0.9);
		align-items: center;
		justify-content: center;
	}
	.lightbox-content {
		max-width: 90%;
		max-height: 90vh;
		border-radius: 8px;
		object-fit: contain;
	}
	.lightbox-close {
		position: absolute;
		top: 15px;
		right: 35px;
		color: #f1f1f1;
		font-size: 40px;
		font-weight: bold;
		cursor: pointer;
	}
	.img-zoomable {
		cursor: zoom-in;
		transition: opacity 0.3s;
	}
	.img-zoomable:hover {
		opacity: 0.9;
	}
</style>