---
// src/layouts/Layout.astro
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content="Mano Amiga Venezuela - Plataforma de apoyo comunitario y ayuda humanitaria de carga rápida." />
		<title>{title} | Mano Amiga Venezuela</title>
	</head>
	<body>
		<header class="main-header">
			<div class="container">
				<a href="/" class="logo"><strong>Mano</strong>Amiga</a>
				<nav>
					<a href="/personas">Buscar Personas</a>
					<a href="/suministros">Suministros</a>
					<a href="/refugios">Refugios</a>
				</nav>
			</div>
		</header>

		<main class="container">
			<slot />
		</main>

		<footer>
			<div class="container text-center">
				<p>Mano Amiga - Plataforma de apoyo comunitario. Diseñada para funcionar sin JavaScript en redes 2G/3G.</p>
			</div>
		</footer>
	</body>
</html>

<style is:global>
	/* CSS RESET & VARIABLES CRÍTICAS DE RENDIMIENTO */
	:root {
		--bg-color: #ffffff;
		--text-color: #111111;
		--primary: #d32f2f; /* Rojo de emergencia */
		--primary-hover: #b71c1c;
		--accent: #0d47a1; /* Azul informativo */
		--gray-light: #f5f5f5;
		--border-color: #cccccc;
	}

	* { box-sizing: border-box; margin: 0; padding: 0; }

	body {
		font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
		background-color: var(--bg-color);
		color: var(--text-color);
		line-height: 1.5;
		font-size: 16px;
	}

	.container {
		width: 100%;
		max-width: 800px;
		margin: 0 auto;
		padding: 12px;
	}

	/* HEADER & NAV */
	.main-header {
		background-color: #111;
		color: #fff;
		padding: 10px 0;
	}
	.main-header .container {
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		gap: 10px;
	}
	.logo { color: #fff; text-decoration: none; font-size: 1.2rem; }
	.logo strong { color: var(--primary); }
	nav a { color: #ccc; text-decoration: none; margin-left: 15px; font-size: 0.95rem; font-weight: 500; }
	nav a:hover { color: #fff; }

	/* FORMULARIOS NATIVOS (ACCESIBLES Y ULTRA LIGEROS) */
	form {
		background: var(--gray-light);
		padding: 16px;
		border-radius: 4px;
		border: 1px solid var(--border-color);
		margin-top: 20px;
	}
	.form-group { margin-bottom: 14px; }
	label { display: block; font-weight: bold; margin-bottom: 4px; font-size: 0.9rem; }
	input[type="text"], input[type="tel"], select, textarea {
		width: 100%;
		padding: 10px;
		border: 1px solid var(--border-color);
		border-radius: 4px;
		font-family: inherit;
		font-size: 1rem;
	}
	textarea { resize: vertical; min-height: 80px; }
	
	button[type="submit"], .btn {
		background-color: var(--primary);
		color: white;
		border: none;
		padding: 12px 20px;
		font-size: 1rem;
		font-weight: bold;
		border-radius: 4px;
		cursor: pointer;
		display: inline-block;
		text-align: center;
		text-decoration: none;
		width: 100%;
	}
	button[type="submit"]:hover, .btn:hover { background-color: var(--primary-hover); }

	.btn-secondary {
		background-color: var(--accent);
	}
	.btn-secondary:hover {
		background-color: #0b3c8a;
	}

	/* UTILIDADES */
	.text-center { text-align: center; }
	.card {
		border: 1px solid var(--border-color);
		padding: 12px;
		margin-bottom: 12px;
		border-radius: 4px;
		background: #fff;
	}
	.badge {
		display: inline-block;
		padding: 2px 6px;
		font-size: 0.8rem;
		font-weight: bold;
		border-radius: 3px;
		text-transform: uppercase;
	}
	.badge-danger { background: #ffcdd2; color: #b71c1c; }
	.badge-success { background: #c8e6c9; color: #1b5e20; }
	.badge-warning { background: #ffecb3; color: #f57f17; }

	footer { margin-top: 40px; padding: 20px 0; border-top: 1px solid var(--border-color); font-size: 0.85rem; color: #666; }
</style>